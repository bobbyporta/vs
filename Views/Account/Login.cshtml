@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>PUB - Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            /* Matched to your dashboard font */
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
            min-height: 100vh;
            background: #ffffff;
            overflow: hidden;
        }

        /* 🔥 The Split Screen Layout */
        .split-layout {
            display: flex;
            min-height: 100vh;
            width: 100vw;
        }

        /* 1. Left Panel (Branding) */
        .left-panel {
            flex: 1;
            background: #0f1c3f; /* Dashboard Navy 800 */
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            overflow: hidden;
        }

        .brand-content {
            z-index: 2;
            text-align: center;
            padding: 40px;
            animation: slideInDown 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }

            .brand-content i {
                font-size: 72px;
                color: #3b82f6; /* Dashboard Accent Blue */
                margin-bottom: 24px;
                filter: drop-shadow(0 10px 20px rgba(59, 130, 246, 0.4));
            }

            .brand-content h1 {
                font-size: 42px;
                font-weight: 800;
                margin-bottom: 12px;
                letter-spacing: -1px;
            }

            .brand-content p {
                font-size: 16px;
                color: rgba(255, 255, 255, 0.6);
                font-weight: 400;
                max-width: 320px;
                margin: 0 auto;
                line-height: 1.5;
            }

        /* Animated Circles restricted to the left panel */
        .circles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 1;
            margin: 0;
            padding: 0;
        }

            .circles li {
                position: absolute;
                display: block;
                list-style: none;
                background: rgba(255, 255, 255, 0.04);
                border-radius: 50%;
                animation: pulseCircle 8s ease-in-out infinite;
            }

                .circles li:nth-child(1) {
                    left: 25%;
                    width: 80px;
                    height: 80px;
                    animation-delay: 0s;
                }

                .circles li:nth-child(2) {
                    left: 10%;
                    width: 40px;
                    height: 40px;
                    animation-delay: 2s;
                }

                .circles li:nth-child(3) {
                    left: 70%;
                    width: 60px;
                    height: 60px;
                    animation-delay: 4s;
                }

                .circles li:nth-child(4) {
                    left: 40%;
                    width: 120px;
                    height: 120px;
                    animation-delay: 1s;
                }

                .circles li:nth-child(5) {
                    left: 65%;
                    width: 30px;
                    height: 30px;
                    animation-delay: 3s;
                }

                .circles li:nth-child(6) {
                    left: 75%;
                    width: 90px;
                    height: 90px;
                    animation-delay: 5s;
                }

                .circles li:nth-child(7) {
                    left: 35%;
                    width: 150px;
                    height: 150px;
                    animation-delay: 2.5s;
                }

        @@keyframes pulseCircle {
            0% {
                transform: scale(0.3);
                opacity: 0;
            }

            50% {
                transform: scale(1);
                opacity: 0.8;
            }

            100% {
                transform: scale(0.3);
                opacity: 0;
            }
        }

        /* 2. Right Panel (Login Form) */
        .right-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #ffffff;
            position: relative;
        }

        .login-container {
            width: 100%;
            max-width: 440px;
            padding: 40px;
            animation: popUp 0.6s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
            opacity: 0;
            transform: scale(0.95);
        }

        @@keyframes popUp {
            0% {
                opacity: 0;
                transform: scale(0.95) translateY(20px);
            }

            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .login-header {
            margin-bottom: 40px;
        }

            .login-header h2 {
                font-size: 28px;
                font-weight: 800;
                color: #0f1c3f;
                margin-bottom: 8px;
                letter-spacing: -0.5px;
            }

            .login-header p {
                font-size: 14.5px;
                color: #64748b;
                font-weight: 500;
            }

        .form-group {
            margin-bottom: 24px;
        }

        /* Floating Label Styles Updated */
        .floating-group {
            position: relative;
        }

        .input-group {
            position: relative;
            display: flex;
            align-items: center;
        }

            .input-group input {
                width: 100%;
                padding: 16px 14px 16px 42px;
                border: 1.5px solid #e2e8f0;
                border-radius: 12px;
                font-size: 14px;
                transition: all 0.3s ease;
                font-family: inherit;
                background: #f8fafc;
                color: #0f172a;
                font-weight: 500;
            }

                .input-group input:focus {
                    outline: none;
                    border-color: #3b82f6; /* Accent Blue */
                    background: white;
                    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.12);
                }

            .input-group i:first-child {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 14px;
                z-index: 2;
                transition: color 0.3s;
            }

            .input-group input:focus ~ i:first-child {
                color: #3b82f6;
            }

        .floating-label {
            position: absolute;
            left: 42px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 14px;
            pointer-events: none;
            transition: all 0.2s ease;
            background: transparent;
            padding: 0 4px;
            font-weight: 500;
        }

        .input-group input:focus + .floating-label,
        .input-group input:not(:placeholder-shown) + .floating-label {
            top: 0;
            transform: translateY(-50%);
            font-size: 11.5px;
            color: #3b82f6;
            background: white;
            font-weight: 700;
        }

        .toggle-password {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #94a3b8;
            transition: color 0.3s ease;
            z-index: 2;
        }

            .toggle-password:hover {
                color: #3b82f6;
            }

        .btn-login {
            width: 100%;
            padding: 15px;
            background: #3b82f6; /* Accent Blue */
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            margin-top: 10px;
            font-family: inherit;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-login:hover {
                background: #2563eb;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(59, 130, 246, 0.35);
            }

            .btn-login:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }

        .spinner {
            display: inline-block;
            width: 18px;
            height: 18px;
            border: 2px solid white;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Mobile Responsiveness */
        @@media (max-width: 900px) {
            .split-layout {
                flex-direction: column;
            }

            .left-panel {
                flex: none;
                height: 300px;
            }

            .brand-content i {
                font-size: 48px;
                margin-bottom: 15px;
            }

            .brand-content h1 {
                font-size: 32px;
            }

            .right-panel {
                border-top-left-radius: 30px;
                border-top-right-radius: 30px;
                margin-top: -30px;
                z-index: 10;
            }
        }

        /* Modal Styles (Kept largely intact but adapted to font) */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 28, 63, 0.6);
            backdrop-filter: blur(4px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

            .modal-overlay.active {
                display: flex;
            }

            .modal-overlay.closing {
                animation: fadeOut 0.3s ease-out forwards;
            }

        @@keyframes fadeOut {
            0% {
                opacity: 1;
            }

            100% {
                opacity: 0;
            }
        }

        .modal-box {
            background: white;
            border-radius: 20px;
            width: 380px;
            text-align: center;
            animation: slideInDown 0.4s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
        }

        @@keyframes slideInDown {
            0% {
                opacity: 0;
                transform: translateY(-30px) scale(0.95);
            }

            100% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @@keyframes slideOutUp {
            0% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }

            100% {
                opacity: 0;
                transform: translateY(-30px) scale(0.95);
            }
        }

        .modal-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 30px auto 20px auto;
            font-size: 32px;
        }

            .modal-icon.error {
                background: #fee2e2;
                color: #dc2626;
            }

            .modal-icon.warning {
                background: #fef3c7;
                color: #d97706;
            }

            .modal-icon.success {
                background: #d1fae5;
                color: #059669;
            }

        .modal-box h3 {
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 12px;
            color: #0f1c3f;
            padding: 0 24px;
        }

        .modal-box p {
            color: #64748b;
            font-size: 14px;
            margin-bottom: 20px;
            padding: 0 30px;
            line-height: 1.5;
            font-weight: 500;
        }

        .modal-box .attempts-left {
            font-size: 12px;
            color: #d97706;
            margin-top: -10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-weight: 600;
        }

        .btn-modal {
            padding: 12px 28px;
            background: #0f1c3f;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 30px;
            transition: all 0.2s ease;
            font-family: inherit;
        }

            .btn-modal:hover {
                background: #1e3a8a;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(15, 28, 63, 0.2);
            }
    </style>
</head>
<body>

    <div class="split-layout">

        <div class="left-panel">
            <div class="brand-content">
                <i class="fas fa-bus"></i>
                <h1>PUB Express</h1>
                <p>Terminal Operations & Fleet Management System</p>
            </div>
        </div>

        <div class="right-panel">
            <div class="login-container">
                <div class="login-header">
                    <h2>Welcome Back</h2>
                    <p>Enter your operator credentials to access the terminal.</p>
                </div>
                <div class="login-body">
                    <form id="loginForm">
                        <div class="form-group floating-group">
                            <div class="input-group">
                                <i class="fas fa-user"></i>
                                <input type="text" id="username" name="username" placeholder=" " autocomplete="off" onfocus="moveLabel(this)" onblur="moveLabel(this)">
                                <label class="floating-label">Username</label>
                            </div>
                        </div>
                        <div class="form-group floating-group">
                            <div class="input-group">
                                <i class="fas fa-lock"></i>
                                <input type="password" id="password" name="password" placeholder=" " onfocus="moveLabel(this)" onblur="moveLabel(this)">
                                <label class="floating-label">Password</label>
                                <i class="fas fa-eye-slash toggle-password" onclick="togglePassword()"></i>
                            </div>
                        </div>
                        <button type="submit" class="btn-login" id="loginBtn">
                            <i class="fas fa-sign-in-alt"></i> Sign In
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>

    <div class="modal-overlay" id="errorModal">
        <div class="modal-box">
            <div class="modal-icon error" id="modalIcon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3 id="modalTitle">Login Failed</h3>
            <p id="modalMessage">Invalid username or password.</p>
            <div id="attemptsMessage" class="attempts-left"></div>
            <button class="btn-modal" onclick="closeModal()">Try Again</button>
        </div>
    </div>

    <script>
        function moveLabel(input) {
            if (input.value !== '') {
                input.setAttribute('placeholder', ' ');
            } else {
                input.setAttribute('placeholder', ' ');
            }
        }

        let loginAttempts = 0;

        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();

            var username = document.getElementById('username').value.trim();
            var password = document.getElementById('password').value;
            var loginBtn = document.getElementById('loginBtn');

            if (!username || !password) {
                showModal('Login Failed', 'Please enter both username and password.', 'error');
                return;
            }

            loginBtn.disabled = true;
            loginBtn.innerHTML = '<span class="spinner"></span> Signing in...';

            fetch('/Account/DoLogin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'username=' + encodeURIComponent(username) + '&password=' + encodeURIComponent(password)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    loginAttempts = 0;
                    window.location.href = '/Home';
                } else {
                    loginAttempts = data.attemptsLeft || 3;

                    if (data.isLocked) {
                        showModal(
                            'Account Locked',
                            'Your account has been locked due to multiple failed login attempts. Please contact the administrator to unlock your account.',
                            'warning'
                        );
                    } else if (data.userNotFound) {
                        showModal(
                            'User Not Found',
                            'No account found with this username. Please check your username or contact admin.',
                            'error'
                        );
                    } else {
                        var attemptsLeft = data.attemptsLeft || 3;
                        var message = 'Invalid username or password.';
                        showModal('Login Failed', message, 'error', attemptsLeft);
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showModal('Error', 'An error occurred. Please try again.', 'error');
            })
            .finally(() => {
                loginBtn.disabled = false;
                loginBtn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Sign In';
            });
        });

        function togglePassword() {
            var passwordInput = document.getElementById('password');
            var toggleIcon = document.querySelector('.toggle-password');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            }
        }

        function showModal(title, message, type, attemptsLeft) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalMessage').innerHTML = message;
            var iconDiv = document.getElementById('modalIcon');
            iconDiv.className = 'modal-icon ' + type;

            if (type === 'error') {
                iconDiv.innerHTML = '<i class="fas fa-exclamation-triangle"></i>';
            } else if (type === 'warning') {
                iconDiv.innerHTML = '<i class="fas fa-lock"></i>';
            }

            var attemptsDiv = document.getElementById('attemptsMessage');
            if (attemptsLeft && attemptsLeft > 0 && attemptsLeft < 3) {
                attemptsDiv.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${attemptsLeft} attempt(s) remaining before account lock`;
                attemptsDiv.style.display = 'flex';
            } else {
                attemptsDiv.style.display = 'none';
            }

            document.getElementById('errorModal').classList.add('active');
        }

        function closeModal() {
            var modal = document.getElementById('errorModal');
            var modalBox = document.querySelector('#errorModal .modal-box');

            modal.classList.add('closing');
            modalBox.style.animation = 'slideOutUp 0.3s cubic-bezier(0.34, 1.2, 0.64, 1) forwards';

            setTimeout(function() {
                modal.classList.remove('active');
                modal.classList.remove('closing');
                modalBox.style.animation = '';
                document.getElementById('password').value = '';
                document.getElementById('username').focus();
            }, 300);
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
            }
        });

        document.getElementById('errorModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
</body>
</html>