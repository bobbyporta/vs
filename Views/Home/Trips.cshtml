@using System.Text.Encodings.Web
@using PUBReservationSystem.Models
@{
    ViewData["Title"] = "Trips & Schedules";
    Layout = "_Layout";

    var role = Context.Session.GetString("Role") ?? "";
    bool isAdmin = role == "Admin";
}

<style>
    /* PAGE ENTRANCE ANIMATIONS */
    @@keyframes pageEnter {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .anim-1 {
        animation: pageEnter 0.4s 0.05s both;
    }

    .anim-2 {
        animation: pageEnter 0.4s 0.10s both;
    }

    .anim-3 {
        animation: pageEnter 0.4s 0.15s both;
    }

    .anim-4 {
        animation: pageEnter 0.4s 0.20s both;
    }

    /* STAT CARDS (Dashboard Style) */
    /* STAT CARDS (Dashboard Style) */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: var(--surface, #ffffff);
        border-radius: var(--radius-lg, 16px);
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        border: 1px solid var(--border, #e2e8f0);
        border-top-width: 4px; /* Thicker top border */
        box-shadow: 0 4px 6px rgba(15, 28, 63, 0.02);
        transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* Specific Card Colors & Hover States */

    /* 1. Total (Blue) */
    .card-total {
        border-top-color: var(--accent, #3b82f6);
    }

        .card-total:hover {
            transform: translateY(-5px);
            border-color: var(--accent, #3b82f6);
            box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15);
        }

    /* 2. Scheduled (Green) */
    .card-scheduled {
        border-top-color: var(--green, #10b981);
    }

        .card-scheduled:hover {
            transform: translateY(-5px);
            border-color: var(--green, #10b981);
            box-shadow: 0 12px 24px rgba(16, 185, 129, 0.15);
        }

    /* 3. In Transit (Orange) */
    .card-intransit {
        border-top-color: #ea580c;
    }

        .card-intransit:hover {
            transform: translateY(-5px);
            border-color: #ea580c;
            box-shadow: 0 12px 24px rgba(234, 88, 12, 0.15);
        }

    /* 4. Completed (Purple) */
    .card-completed {
        border-top-color: #9333ea;
    }

        .card-completed:hover {
            transform: translateY(-5px);
            border-color: #9333ea;
            box-shadow: 0 12px 24px rgba(147, 51, 234, 0.15);
        }

    .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .icon-total {
        background: var(--navy-50);
        color: var(--accent);
    }

    .icon-sched {
        background: var(--green-soft);
        color: var(--green);
    }

    .icon-transit {
        background: #fff7ed;
        color: #ea580c;
    }

    .icon-comp {
        background: #f3e8ff;
        color: #9333ea;
    }

    .stat-info h3 {
        margin: 0;
        font-size: 24px;
        font-weight: 800;
        color: var(--navy-800);
        line-height: 1.2;
    }

    .stat-info span {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* TOOLBAR */
    .filter-toolbar-card {
        background: var(--surface);
        padding: 16px 20px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        margin-bottom: 24px;
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .toolbar-left {
        display: flex;
        gap: 12px;
        align-items: center;
        flex: 1;
    }

    .toolbar-right {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    /* TRIPS GRID */
    .trips-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
        padding-bottom: 20px;
    }

    .trip-card {
        background: white;
        border-radius: 16px;
        padding: 22px;
        border: 1px solid var(--border);
        box-shadow: 0 4px 6px rgba(15, 28, 63, 0.02);
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

        .trip-card:hover {
            box-shadow: 0 8px 16px rgba(15, 28, 63, 0.06);
        }

    .trip-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .trip-title-area {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .bus-icon-wrap {
        width: 40px;
        height: 40px;
        background: var(--navy-50);
        color: var(--navy-800);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
    }

    .trip-title-area h5 {
        margin: 0;
        font-size: 15px;
        font-weight: 700;
        color: var(--navy-800);
    }

    .trip-title-area span {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 600;
    }

    /* STATUS PILLS */
    .trip-status {
        font-size: 11px;
        font-weight: 700;
        padding: 5px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid transparent;
        transition: all 0.2s;
    }

    .status-Scheduled {
        background: var(--green-soft);
        color: var(--green);
    }

    .status-In-Transit {
        background: #fff7ed;
        color: #ea580c;
    }

    .status-Completed {
        background: #f3e8ff;
        color: #9333ea;
    }

    .status-Cancelled {
        background: var(--red-soft);
        color: var(--red);
    }

    /* Dispatcher Editable Pill */
    .status-editable {
        cursor: pointer;
        border-style: dashed;
    }

        .status-editable:hover {
            filter: brightness(0.95);
            transform: scale(1.02);
        }

    /* TRIP DETAILS */
    .trip-details {
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #f8fafd;
        padding: 16px;
        border-radius: 12px;
    }

    .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        font-size: 13.5px;
        color: var(--text-primary);
    }

        .detail-row i {
            width: 16px;
            text-align: center;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .detail-row strong {
            color: var(--navy-800);
            font-weight: 600;
        }

    /* MODALS (From Reservation CSS) */
    @@keyframes modalFadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
    @@keyframes modalFadeOut {
        from {
            opacity: 1;
        }

        to {
            opacity: 0;
        }
    }
    @@keyframes modalPopIn {
        from {
            transform: scale(0.95) translateY(20px);
            opacity: 0;
        }

        to {
            transform: scale(1) translateY(0);
            opacity: 1;
        }
    }
    @@keyframes modalPopOut {
        from {
            transform: scale(1) translateY(0);
            opacity: 1;
        }

        to {
            transform: scale(0.95) translateY(20px);
            opacity: 0;
        }
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,28,63,0.6);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(3px);
    }

        .modal-overlay.show {
            display: flex;
            animation: modalFadeIn 0.25s ease-out forwards;
        }

        .modal-overlay.hide {
            display: flex;
            animation: modalFadeOut 0.2s ease-in forwards;
        }

    .sys-modal {
        background: white;
        border-radius: var(--radius-lg, 16px);
        width: 90%;
        max-width: 500px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        display: flex;
        flex-direction: column;
    }

    .modal-overlay.show .sys-modal {
        animation: modalPopIn 0.3s cubic-bezier(0.175,0.885,0.32,1.275) forwards;
    }

    .modal-overlay.hide .sys-modal {
        animation: modalPopOut 0.2s ease-in forwards;
    }

    .modal-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header h4 {
            margin: 0;
            font-size: 16px;
            font-weight: 700;
            color: var(--navy-800);
        }

    .btn-close-modal {
        background: none;
        border: none;
        font-size: 20px;
        color: var(--text-muted);
        cursor: pointer;
        transition: color 0.2s;
    }

        .btn-close-modal:hover {
            color: var(--red);
        }

    .modal-body {
        padding: 24px;
        flex: 1;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        background: #f8fafd;
        border-radius: 0 0 16px 16px;
    }

    .form-group {
        margin-bottom: 16px;
    }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13.5px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: border-color 0.2s;
    }

        .form-control:focus {
            border-color: var(--accent);
            outline: none;
            box-shadow: 0 0 0 3px rgba(59,108,247,0.1);
        }

    .trip-footer {
        display: flex;
        justify-content: space-between; /* Pushes ID to left, buttons to right */
        align-items: center;
        border-top: 1px dashed #e2e8f0;
        margin-top: auto;
        padding-top: 12px;
    }

    .dispatch-btn {
        padding: 5px 12px;
        font-size: 11px;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        margin-left: 8px;
        transition: 0.2s;
    }

    .btn-dispatch {
        background: #10b981;
        color: white;
    }
    /* Green */
    .btn-cancel {
        background: #ef4444;
        color: white;
    }
    /* Red */
    .btn-dispatch:hover {
        background: #059669;
    }

    .btn-cancel:hover {
        background: #dc2626;
    }

    /* Capacity Pill Styles */
    .capacity-pill {
        font-size: 11px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 6px;
        color: white;
    }

    .cap-green {
        background: #10b981;
    }

    .cap-yellow {
        background: #f59e0b;
    }

    .cap-red {
        background: #ef4444;
    }

    .btn-book-teller {
        padding: 5px 12px;
        font-size: 11px;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        background: var(--accent);
        color: white;
        transition: 0.2s;
    }

        .btn-book-teller:hover {
            background: #2563eb;
        }

    /* Adds a red asterisk to any label with the 'required' class */
    .required::after {
        content: ' *';
        color: #ef4444; /* Matches your system's red theme */
        font-weight: 800;
        margin-left: 3px;
    }
</style>

@* PAGE HEADER *@
<div class="page-header anim-1" style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom: 24px;">
    <div>
        <h2 style="font-size:20px; font-weight:800; color:var(--navy-800); margin:0; display:flex; align-items:center; gap:10px;">
            <i class="fas fa-route" style="color:var(--accent);"></i> Trips & Schedules
        </h2>
        <p style="font-size:13px; color:var(--text-secondary); margin:3px 0 0;">
            Manage fleet scheduling, routes, and operational statuses.
        </p>
        <p style="color:red;">DEBUG: Current Session Branch ID = @ViewBag.DebugBranchId</p>
    </div>
    <div style="display:flex; align-items:center; gap:8px;">
        @if (ViewBag.Role == "Admin")
        {
            <span style="font-size:13px; font-weight:600; color:var(--green); display:flex; align-items:center; gap:6px; background: var(--green-soft); padding: 6px 12px; border-radius: 20px;">
                <i class="fas fa-user-cog"></i> Dispatch & Admin Control
            </span>
        }
        else
        {
            <span style="font-size:13px; font-weight:600; color:var(--text-primary); display:flex; align-items:center; gap:6px;">
                <i class="fas fa-eye"></i> View-Only Access
            </span>
        }
    </div>
</div>

@* STAT CARDS *@
<div class="stat-grid anim-2">
    <div class="stat-card card-total">
        <div class="stat-icon icon-total"><i class="fas fa-list-ul"></i></div>
        <div class="stat-info">
            <h3 id="stat-total">@ViewBag.TotalTrips</h3>
            <span>Total Trips</span>
        </div>
    </div>
    <div class="stat-card card-scheduled">
        <div class="stat-icon icon-sched"><i class="fas fa-clock"></i></div>
        <div class="stat-info">
            <h3 id="stat-scheduled">@ViewBag.Scheduled</h3>
            <span>Scheduled</span>
        </div>
    </div>
    <div class="stat-card card-intransit">
        <div class="stat-icon icon-transit"><i class="fas fa-road"></i></div>
        <div class="stat-info">
            <h3 id="stat-intransit">@ViewBag.InTransit</h3>
            <span>In Transit</span>
        </div>
    </div>
    <div class="stat-card card-completed">
        <div class="stat-icon icon-comp"><i class="fas fa-check-double"></i></div>
        <div class="stat-info">
            <h3 id="stat-completed">@ViewBag.Completed</h3>
            <span>Completed</span>
        </div>
    </div>
</div>

@* FILTER TOOLBAR *@
<div class="filter-toolbar-card anim-3">
    <div class="toolbar-left">
        <div style="position:relative; width: 280px;">
            <i class="fas fa-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:13px;"></i>
            <input type="text" id="searchTrip" class="form-control" style="padding-left:38px;" placeholder="Search route (e.g. Cebu to Ormoc)..." onkeyup="filterTrips()">
        </div>
        <select id="filterStatus" class="form-control" style="width:160px;" onchange="filterTrips()">
            <option value="">All Statuses</option>
            <option value="Scheduled">Scheduled</option>
            <option value="In Transit">In Transit</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>
        </select>
        <button class="btn-ghost-sys" onclick="resetTripFilters()"><i class="fas fa-times"></i> Clear</button>
    </div>

    <div class="toolbar-right">
        @if (ViewBag.Role == "Admin")
        {
            <button class="btn-primary-sys" onclick="openModal('createTripModal')">
                <i class="fas fa-plus"></i> Create New Trip
            </button>
        }
    </div>
</div>

@* TRIPS GRID *@
<div class="trips-grid anim-4" id="tripsGrid">
    @foreach (var trip in ((List<PUBReservationSystem.Models.Trip>)ViewBag.OutgoingTrips).OrderByDescending(t => t.Scheduled_Departure_Time))
    {
        var safeStatusClass = trip.Status?.Trim().Replace(" ", "-") ?? "Unknown";
        var isDispatcher = (ViewBag.Role == "Admin" || ViewBag.Role == "Dispatcher");
        var isTeller = (ViewBag.Role == "Teller" || ViewBag.Role == "HeadTeller");

        // --- DYNAMIC BOOKING MATH ---
        // Ensure trip.Trip_ID is treated as a string for the Dictionary lookup
        // --- DYNAMIC BOOKING MATH ---
        var bookingCounts = ViewBag.BookingCounts as Dictionary<string, int>;

        // ✅ FIX: Added .Trim() back to strip the SQL whitespaces!
        string tripIdKey = trip.Trip_ID?.Trim();

        int booked = (bookingCounts != null && tripIdKey != null && bookingCounts.ContainsKey(tripIdKey))
        ? bookingCounts[tripIdKey]
        : 0;
        int total = 45; // Default capacity
        int vacant = total - booked;
        string capClass = vacant > 10 ? "cap-green" : (vacant > 0 ? "cap-yellow" : "cap-red");

        // Format Bus Type
        string busType = trip.Bus?.Bus_Type == "AC" ? "Aircon" : (trip.Bus?.Bus_Type == "OR" ? "Ordinary" : "Unknown");

        <div class="trip-card" data-route="@(trip.Origin?.ToLower() + " " + trip.Destination?.ToLower())" data-status="@trip.Status">

            @* HEADER *@
            <div class="trip-header">
                <div class="trip-title-area">
                    <div class="bus-icon-wrap"><i class="fas fa-bus-alt"></i></div>
                    <div>
                        <h5>@(trip.Bus?.Bus_Name ?? "Unknown Bus")</h5>
                        <span style="text-transform: uppercase;">
                            @(trip.Bus?.Body_Bus_Number ?? "No Plate") &bull; @busType
                        </span>
                    </div>
                </div>
                <span class="trip-status status-@safeStatusClass @(isDispatcher ? "status-editable" : "")"
                      @Html.Raw(isDispatcher ? $"onclick=\"openStatusModal('{trip.Trip_ID}', '{trip.Status}')\"" : "")
                      title="Click to update status">
                    @trip.Status
                </span>
            </div>

            @* BODY DETAILS *@
            <div class="trip-details" style="display: flex; flex-direction: column; gap: 12px;">

                <div class="detail-row">
                    <i class="fas fa-map-marker-alt" style="color: var(--accent);"></i>
                    <span><strong>@trip.Origin</strong> &rarr; <strong>@trip.Destination</strong></span>
                </div>

                <div class="detail-row">
                    <i class="fas fa-calendar-alt"></i>
                    <span>@(trip.Scheduled_Departure_Time?.ToString("MMM dd, yyyy — hh:mm tt") ?? "TBA")</span>
                </div>

                <div class="detail-row" style="justify-content: space-between; border-top: 1px solid #e2e8f0; padding-top: 10px; margin-top: 2px;">
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <i class="fas fa-ticket-alt" style="color: var(--green);"></i>
                        <span>Fare: <strong>₱@trip.Base_Fare.ToString("N2")</strong></span>
                    </div>
                    <div style="display: flex; gap: 8px; align-items: center;">
                        <i class="fas fa-users" style="color: var(--navy-800);"></i>
                        <span>Booked: <strong>@booked</strong> / @total Pax</span>
                    </div>
                </div>

                <div class="detail-row" style="justify-content: space-between; font-size: 11.5px;">
                    <div style="display: flex; gap: 8px; align-items: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="Driver">
                        <i class="fas fa-steering-wheel" style="color: var(--text-muted);"></i>
                        <span><strong>DRV:</strong> @(trip.Driver != null ? $"[{trip.Driver.Employee_ID}] {trip.Driver.Full_Name}" : "Unassigned")</span>
                    </div>
                    <div style="display: flex; gap: 8px; align-items: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="Conductor">
                        <i class="fas fa-user-tag" style="color: var(--text-muted);"></i>
                        <span><strong>CON:</strong> @(trip.Conductor != null ? $"[{trip.Conductor.Employee_ID}] {trip.Conductor.Full_Name}" : "None")</span>
                    </div>
                </div>
            </div>

            @* FOOTER *@
            <div class="trip-footer">
                <div style="font-size: 11px; font-weight: 600; color: #94a3b8; letter-spacing: 0.5px;">
                    TRIP ID: @trip.Trip_ID
                </div>
                <div class="action-buttons">
                    @if (isTeller && vacant > 0)
                    {
                        <button class="btn-book-teller" onclick="window.location.href='/Home/Reservations?tripId=@trip.Trip_ID'">
                            <i class="fas fa-ticket-alt"></i> Book Now
                        </button>
                    }
                    @if (isDispatcher && trip.Status == "Scheduled" && trip.Scheduled_Departure_Time?.Date == DateTime.Today)
                    {
                        <button class="dispatch-btn btn-dispatch" onclick="dispatchTrip('@trip.Trip_ID')">Dispatch</button>
                        <button class="dispatch-btn btn-cancel" onclick="cancelTrip('@trip.Trip_ID')">Cancel</button>
                    }
                </div>
            </div>
        </div>
    }
</div>

<hr class="my-5" />

<h3 class="mb-4">Incoming Buses (Arriving at @ViewBag.MyBranch)</h3>

@if (ViewBag.IncomingTrips != null && ViewBag.IncomingTrips.Count > 0)
{
    <div class="trips-grid">
        @foreach (var trip in ViewBag.IncomingTrips)
        {
            <div class="trip-card">
                <div class="trip-header">
                    <div class="trip-title-area">
                        <div class="bus-icon-wrap" style="background: rgba(13, 202, 240, 0.1); color: #0dcaf0;">
                            <i class="fas fa-bus-alt"></i>
                        </div>
                        <div>
                            <h5>@trip.Bus.Bus_Name</h5>
                            <span>@trip.Bus.Plate_Number</span>
                        </div>
                    </div>

                    @* NEW FIX: Dynamic Badge Rendering *@
                    @if (trip.Status == "Completed")
                    {
                        <span class="trip-status status-Completed">ARRIVED</span>
                    }
                    else
                    {
                        <span class="trip-status status-In-Transit">INCOMING</span>
                    }
                </div>

                <div class="trip-details">
                    <div class="detail-row">
                        <i class="fas fa-map-marker-alt" style="color: var(--accent);"></i>
                        <span>From: <strong>@trip.Origin</strong></span>
                    </div>
                    <div class="detail-row">
                        <i class="fas fa-clock"></i>
                        <span>Dispatched: <strong>@(trip.Actual_Dispatch_Time?.ToString("hh:mm tt") ?? "N/A")</strong></span>
                    </div>

                    @* Added the Driver/Conductor info to match your main cards *@
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px;">
                        <div class="detail-row" title="Driver">
                            <i class="fas fa-id-badge"></i>
                            <span style="font-size: 12px;">@(trip.Driver?.Full_Name ?? "Unassigned")</span>
                        </div>
                        <div class="detail-row" title="Conductor">
                            <i class="fas fa-user-tag"></i>
                            <span style="font-size: 12px;">@(trip.Conductor?.Full_Name ?? "None")</span>
                        </div>
                    </div>
                </div>

                <div class="trip-footer">
                    <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px;">
