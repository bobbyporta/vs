<script>
        function completeTrip(tripId) {
        if (!confirm("Has this bus safely arrived?")) return;

        fetch('/Home/UpdateTripStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            // FIX: Safe encoding
            body: new URLSearchParams({ tripId: tripId, newStatus: 'Completed' })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert("Error: " + data.message);
            }
        })
        .catch(error => console.error('Error:', error));
    }
</script>

@section Scripts {
    <script>
        const isDispatcher = @(ViewBag.Role == "Dispatcher" ? "true" : "false");
        // --- ANIMATE NUMBERS FUNCTION ---
        function animateValue(id, start, end, duration) {
            let obj = document.getElementById(id);
            if (!obj) return;
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                obj.innerHTML = Math.floor(progress * (end - start) + start);
                if (progress < 1) {
                    window.requestAnimationFrame(step);
                } else {
                    obj.innerHTML = end; // Ensure exact final value
                }
            };
            window.requestAnimationFrame(step);
        }


        function markTripArrived(tripId) {
            if (!confirm("Confirm that this bus has arrived at your branch?")) return;

            fetch('/Home/MarkTripArrived', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'tripId=' + encodeURIComponent(tripId)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload(); // Reload to move the card to 'Completed' status
                } else {
                    alert(data.message || 'Error updating status.');
                }
            })
            .catch(err => console.error(err));
        }

                // DISPATCH TRIP FUNCTION
                function dispatchTrip(tripId) {
            if (!confirm("Confirm dispatching this bus?")) return;

            fetch('/Home/UpdateTripStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                // FIX: URLSearchParams safely encodes the space in "In Transit"
                body: new URLSearchParams({ tripId: tripId, newStatus: 'In Transit' })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert("Error: " + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert("An error occurred while communicating with the server.");
            });
        }

        // CANCEL TRIP FUNCTION (Since you have a Cancel button next to it!)
                function cancelTrip(tripId) {
            if (!confirm("Are you sure you want to cancel this trip?")) return;

            fetch('/Home/UpdateTripStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                // FIX: Safe encoding
                body: new URLSearchParams({ tripId: tripId, newStatus: 'Cancelled' })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert("Error: " + data.message);
                }
            });
        }



                // ==========================================
        // ROUTE ENFORCEMENT & CASCADING DROPDOWNS
        // ==========================================
        var activeRoutes = [];
        var allBranchOptions = []; // Stores the original HTML branches

        document.addEventListener('DOMContentLoaded', function() {
            // 1. Backup the original destination options before we erase them
            var destSelect = document.getElementById('destBranchId');
            for (var i = 1; i < destSelect.options.length; i++) {
                allBranchOptions.push({
                    value: destSelect.options[i].value,
                    text: destSelect.options[i].text
                });
            }

            // 2. Fetch valid routes from the database
            fetch('/Home/GetAllRoutes')
                .then(res => res.json())
                .then(data => {
                    activeRoutes = data;
                    initCascadingLogic();
                })
                .catch(err => console.error("Error loading routes:", err));
        });

        // Prevent old HTML onclicks from throwing errors
        window.calculateFare = function() { };

        // HELPER: Strips "Branch" and "City" so "Cebu City" matches "Cebu Branch"
        const normalize = (str) => {
            if (!str) return '';
            return str.toLowerCase()
                      .replace('branch', '')
                      .replace('city', '')
                      .trim();
        };

        function initCascadingLogic() {
            var originSelect = document.getElementById('originBranchId');
            var destSelect = document.getElementById('destBranchId');
            var fareInput = document.getElementById('newTripFare');

            // STEP 1: Lock destination dropdown on load
            destSelect.disabled = true;

            // STEP 2: Disable invalid origins
            var validOriginNames = activeRoutes.map(r => normalize(r.origin));
            for (var i = 1; i < originSelect.options.length; i++) {
                var branchName = normalize(originSelect.options[i].text);
                if (!validOriginNames.includes(branchName)) {
                    originSelect.options[i].style.display = 'none';
                    originSelect.options[i].disabled = true;
                }
            }

            // STEP 3: Rebuild destinations when Origin changes
            originSelect.addEventListener('change', function() {
                // Always reset the destination dropdown and fare first
                destSelect.innerHTML = '<option value="">-- Select Destination --</option>';
                fareInput.value = '';

                if (this.selectedIndex <= 0) {
                    destSelect.disabled = true;
                    return;
                }

                destSelect.disabled = false;
                var selectedOriginName = normalize(this.options[this.selectedIndex].text);

                // Find destinations that ONLY match the chosen origin
                var validDestNames = activeRoutes
                    .filter(r => normalize(r.origin) === selectedOriginName)
                    .map(r => normalize(r.destination));

                // Rebuild destination dropdown using the backed-up options
                allBranchOptions.forEach(opt => {
                    var optNormalized = normalize(opt.text);
                    if (validDestNames.includes(optNormalized)) {
                        var newOption = document.createElement('option');
                        newOption.value = opt.value;
                        newOption.text = opt.text;
                        destSelect.appendChild(newOption);
                    }
                });
            });

            // STEP 4: Auto-fill fare when Destination changes
            destSelect.addEventListener('change', function() {
                if (this.selectedIndex <= 0 || originSelect.selectedIndex <= 0) {
                    fareInput.value = '';
                    return;
                }

                var selectedOriginName = normalize(originSelect.options[originSelect.selectedIndex].text);
                var selectedDestName = normalize(this.options[this.selectedIndex].text);

                var matchingRoute = activeRoutes.find(r =>
                    normalize(r.origin) === selectedOriginName &&
                    normalize(r.destination) === selectedDestName
                );

                if (matchingRoute) {
                    var fare = matchingRoute.baseFare || matchingRoute.base_Fare || 0;
                    fareInput.value = parseFloat(fare).toFixed(2);
                } else {
                    fareInput.value = '';
                }
            });
        }




































         












        // --- STAT COUNTER HELPERS ---
        function updateStatCounter(id, delta) {
            let el = document.getElementById(id);
            if (!el) return;
            let current = parseInt(el.textContent) || 0;
            let target = current + delta;
            if (target < 0) target = 0;
            animateValue(id, current, target, 400);
        }


        // --- AUTO-FILL FARE BASED ON ROUTE SELECTION ---
        function handleRouteSelection() {
            var destSelect = document.getElementById('newTripDest');
            var fareInput = document.getElementById('newTripFare');

            if (destSelect.selectedIndex > 0) {
                var opt = destSelect.options[destSelect.selectedIndex];
                var fare = opt.getAttribute('data-fare');

                if (fare && fare > 0) {
                    fareInput.value = parseFloat(fare).toFixed(2);
                } else {
                    fareInput.value = '';
                }
            } else {
                fareInput.value = '';
            }
        }

        // --- FORMATTERS ---
        function formatLocationName(inputElement) {
            let val = inputElement.value.replace(/[^a-zA-Z\s]/g, '');
            let words = val.split(' ');
            for(let i = 0; i < words.length; i++) {
                if(words[i].length > 0) {
                    words[i] = words[i].charAt(0).toUpperCase() + words[i].slice(1).toLowerCase();
                }
            }
            inputElement.value = words.join(' ');
        }

        function formatTo12Hour(timeStr) {
            let [hour, minute] = timeStr.split(':');
            let h = parseInt(hour);
            let ampm = h >= 12 ? 'PM' : 'AM';
            h = h % 12;
            h = h ? h : 12;
            let paddedHour = h < 10 ? '0' + h : h;
            return `${paddedHour}:${minute} ${ampm}`;
        }

        function formatDateShort(dateStr) {
            const date = new Date(dateStr);
            const options = { month: 'short', day: '2-digit', year: 'numeric' };
            return date.toLocaleDateString('en-US', options);
        }

        // --- MODAL CONTROLS ---
        function openModal(id) {
            var m = document.getElementById(id);
            if (!m) return;
            m.classList.remove('hide');
            m.classList.add('show');
            document.body.style.overflow = 'hidden';

            if(id === 'createTripModal') {
                document.getElementById('createTripForm').reset();
                // ✅ FIXED: Removed fetchRoutesForTrips() to eliminate client-side script crashes
            }
        }

        function closeModal(id) {
            var m = document.getElementById(id);
            if (!m) return;
            m.classList.remove('show');
            m.classList.add('hide');
            setTimeout(function () {
                m.classList.remove('hide');
                if (!document.querySelector('.modal-overlay.show'))
                    document.body.style.overflow = '';
            }, 220);
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                var open = document.querySelectorAll('.modal-overlay.show');
                if (open.length) closeModal(open[open.length - 1].id);
            }
        });



        // ==========================================
// BACKGROUND POLLING FOR LIVE STATS
// ==========================================
const myBranchId = parseInt('@ViewBag.DebugBranchId') || 0;

function fetchLiveStats() {
    // Prevent polling if branch ID isn't loaded properly
    if (myBranchId === 0) return; 

    fetch(`/Home/GetLiveStats?branchId=${myBranchId}`)
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Get current numbers on the screen
                let currentTotal = parseInt(document.getElementById('stat-total').innerText) || 0;
                let currentSched = parseInt(document.getElementById('stat-scheduled').innerText) || 0;
                let currentTransit = parseInt(document.getElementById('stat-intransit').innerText) || 0;
                let currentComp = parseInt(document.getElementById('stat-completed').innerText) || 0;

                // Animate ONLY if the numbers have changed!
                if (currentTotal !== data.total) animateValue('stat-total', currentTotal, data.total, 400);
                if (currentSched !== data.scheduled) animateValue('stat-scheduled', currentSched, data.scheduled, 400);
                if (currentTransit !== data.inTransit) animateValue('stat-intransit', currentTransit, data.inTransit, 400);
                if (currentComp !== data.completed) animateValue('stat-completed', currentComp, data.completed, 400);
            }
        })
        .catch(err => console.error("Error fetching live stats: ", err));
}

// Start the polling loop. 5000 = 5 seconds. 
// Change to 10000 if you want it to check every 10 seconds instead.
setInterval(fetchLiveStats, 2000);














        // --- FILTERING ---
                function filterTrips() {
            // 1. Get values from the inputs
            const searchTerm = document.getElementById('searchTrip').value.toLowerCase();
            const statusFilter = document.getElementById('filterStatus').value;

            // 2. Get all trip cards
            const cards = document.querySelectorAll('.trip-card');
            let staggerDelay = 0;

            cards.forEach(card => {
                // Grab route from data-attribute (make sure your card has data-route="origin destination")
                const route = card.getAttribute('data-route') || "";
                const status = card.getAttribute('data-status') || "";

                // 3. Logic: Does it match the Search AND the Status?
                const matchesSearch = route.includes(searchTerm);
                const matchesStatus = (statusFilter === "" || status === statusFilter);

                if (matchesSearch && matchesStatus) {
                    card.style.display = 'flex'; // Show card

                    // Animation Trigger
                    card.style.animation = 'none';
                    void card.offsetWidth; // Force Reflow
                    card.style.animation = `modalPopIn 0.4s ease-out ${staggerDelay}s forwards`;
                    staggerDelay += 0.05; // Stagger effect
                } else {
                    card.style.display = 'none'; // Hide card
                }
            });
        }

        function resetTripFilters() {
            document.getElementById('searchTrip').value = "";
            document.getElementById('filterStatus').value = "";
            filterTrips(); // Re-run filter to show all

            // ✅ Add the success toast notification
            if (typeof showToast === "function") {
                showToast("Trip filters reset successfully!", "success");
            }
        }

        // --- DISPATCHER ONLY: CREATE TRIP ---
                function submitNewTrip(e) {
            e.preventDefault();

            // 1. UI Feedback
            var btn = document.getElementById('btnSaveTrip');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

            // 2. Capture Form Data
            var busId = document.getElementById('assignedBusId').value;
            var originBranchId = document.getElementById('originBranchId').value;
            var destBranchId = document.getElementById('destBranchId').value;
            var driverId = document.getElementById('assignedDriverId').value;
            var conductorId = document.getElementById('assignedConductorId').value;
            var date = document.getElementById('newTripDate').value;
            var time = document.getElementById('newTripTime').value;
            var fare = document.getElementById('newTripFare').value;

            // Get the display TEXT of the select elements for Origin/Destination names
            var originSelect = document.getElementById('originBranchId');
            var originName = originSelect.options[originSelect.selectedIndex].text;

            var destSelect = document.getElementById('destBranchId');
            var destName = destSelect.options[destSelect.selectedIndex].text;

            // 3. Strict Validation
            if (!busId || !originBranchId || !destBranchId || !driverId || !date || !time || !fare) {
                alert('Please fill in all required fields.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save"></i> Save Schedule';
                return;
            }

            // 4. Build Payload
            var formData = new URLSearchParams();
            formData.append('busId', busId);
            formData.append('driverId', driverId);
            formData.append('conductorId', conductorId);
            formData.append('origin', originName);            // String Name
            formData.append('destination', destName);        // String Name
            formData.append('baseFare', fare);
            formData.append('departureTime', date + ' ' + time); // Combined Date & Time
            formData.append('originBranchId', originBranchId);   // Integer ID
            formData.append('destinationBranchId', destBranchId);// Integer ID

            // 5. Send POST Request
            fetch('/Home/SaveTrip', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    document.getElementById('createTripForm').reset();
                    closeModal('createTripModal');
                    showToast(data.message, 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    alert(data.message || 'Error creating trip.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-save"></i> Save Schedule';
                }
            })
            .catch(err => {
                console.error(err);
                alert('Network error while creating trip.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save"></i> Save Schedule';
            });
        }

        // --- FETCH ROUTES DYNAMICALLY ---
        

        // --- AUTO-FILL ORIGIN WHEN ROUTE IS SELECTED ---
        function autoFillOrigin() {
            var destSelect = document.getElementById('newTripDest');
            var originInput = document.getElementById('newTripOrigin');

            if (destSelect.selectedIndex > 0) {
                var opt = destSelect.options[destSelect.selectedIndex];
                var orig = opt.getAttribute('data-origin');
                if (orig) {
                    originInput.value = orig;
                }
            }
        }

        function insertTripCard(tripId, busName, busNum, origin, dest, dateRaw, timeRaw, fareNum, driverDisplay, conductorDisplay, isDispatcher) {
            const grid = document.getElementById('tripsGrid');

            // Formatting Helpers
            const displayDate = formatDateShort(dateRaw);
            const displayTime = formatTo12Hour(timeRaw);
            const displayFare = fareNum.toLocaleString('en-US', { minimumFractionDigits: 2 });
            const searchTag = `${origin} ${dest}`.toLowerCase();

            const today = new Date().toISOString().split('T')[0];
            const showButtons = (isDispatcher === true && dateRaw === today);

            const cardHtml = `
            <div class="trip-card" data-route="${searchTag}" data-status="Scheduled" style="animation: modalPopIn 0.4s ease-out forwards;">
                <div class="trip-header">
                    <div class="trip-title-area">
                        <div class="bus-icon-wrap"><i class="fas fa-bus-alt"></i></div>
                        <div>
                            <h5>${busName}</h5>
                            <span style="text-transform: uppercase;">${busNum}</span>
                        </div>
                    </div>
                    <span class="trip-status status-Scheduled status-editable" onclick="openStatusModal('${tripId}', 'Scheduled')" id="pill-${tripId}" title="Click to update status">
                        Scheduled
                    </span>
                </div>

                <div class="trip-details" style="display: flex; flex-direction: column; gap: 12px;">
                    <div class="detail-row">
                        <i class="fas fa-map-marker-alt" style="color: var(--accent);"></i>
                        <span><strong>${origin}</strong> &rarr; <strong>${dest}</strong></span>
                    </div>

                    <div class="detail-row">
                        <i class="fas fa-calendar-alt"></i>
                        <span>${displayDate} — ${displayTime}</span>
                    </div>

                    <div class="detail-row" style="justify-content: space-between; border-top: 1px solid #e2e8f0; padding-top: 10px; margin-top: 2px;">
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <i class="fas fa-ticket-alt" style="color: var(--green);"></i>
                            <span>Fare: <strong>₱${displayFare}</strong></span>
                        </div>
                        <div style="display: flex; gap: 8px; align-items: center;">
                            <i class="fas fa-users" style="color: var(--navy-800);"></i>
                            <span>Booked: <strong>0</strong> / 45 Pax</span>
                        </div>
                    </div>

                    <div class="detail-row" style="justify-content: space-between; font-size: 11.5px;">
                        <div style="display: flex; gap: 8px; align-items: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="Driver">
                            <i class="fas fa-steering-wheel" style="color: var(--text-muted);"></i>
                            <span><strong>DRV:</strong> ${driverDisplay}</span>
                        </div>
                        <div style="display: flex; gap: 8px; align-items: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="Conductor">
                            <i class="fas fa-user-tag" style="color: var(--text-muted);"></i>
                            <span><strong>CON:</strong> ${conductorDisplay}</span>
                        </div>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed var(--border, #e2e8f0); margin-top: auto; padding-top: 12px;">
                    <div style="font-size: 11px; font-weight: 600; color: var(--text-muted, #94a3b8); letter-spacing: 0.5px;">
                        TRIP ID: ${tripId}
                    </div>

                    ${showButtons ? `
                    <div class="action-buttons">
                        <button class="dispatch-btn btn-dispatch" onclick="dispatchTrip('${tripId}')" style="padding: 4px 10px; font-size: 11px; border-radius: 4px; border: none; cursor: pointer; background: #10b981; color: white; margin-left: 8px;">
                            Dispatch
                        </button>
                        <button class="dispatch-btn btn-cancel" onclick="cancelTrip('${tripId}')" style="padding: 4px 10px; font-size: 11px; border-radius: 4px; border: none; cursor: pointer; background: #ef4444; color: white; margin-left: 8px;">
                            Cancel
                        </button>
                    </div>
                    ` : ''}
                </div>
            </div>
            `;

            grid.insertAdjacentHTML('afterbegin', cardHtml);
        }

        // --- DISPATCHER ONLY: UPDATE STATUS ---
        function openStatusModal(tripId, currentStatus) {
            document.getElementById('editTripId').value = tripId;
            document.getElementById('oldTripStatus').value = currentStatus;
            document.getElementById('editTripStatus').value = currentStatus;
            openModal('updateStatusModal');
        }

                function submitStatusUpdate() {
            var tripId = document.getElementById('editTripId').value;
            var oldStatus = document.getElementById('oldTripStatus').value;
            var newStatus = document.getElementById('editTripStatus').value;

            if (oldStatus === newStatus) {
                closeModal('updateStatusModal');
                return;
            }

            // ✅ FIX: Changed to x-www-form-urlencoded to perfectly match your C# Controller!
            fetch('/Home/UpdateTripStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `tripId=${encodeURIComponent(tripId)}&newStatus=${encodeURIComponent(newStatus)}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    closeModal('updateStatusModal');
                    // ... (keep the rest of your success logic exactly as is)

                    // Adjust stats
                    if (oldStatus === 'Scheduled') updateStatCounter('stat-scheduled', -1);
                    if (oldStatus === 'In Transit') updateStatCounter('stat-intransit', -1);
                    if (oldStatus === 'Completed') updateStatCounter('stat-completed', -1);

                    if (newStatus === 'Scheduled') updateStatCounter('stat-scheduled', 1);
                    if (newStatus === 'In Transit') updateStatCounter('stat-intransit', 1);
                    if (newStatus === 'Completed') updateStatCounter('stat-completed', 1);

                    // Update UI pill
                    var pill = document.getElementById(`pill-${tripId}`);
                    var card = pill.closest('.trip-card');

                    if (pill && card) {
                        pill.className = `trip-status status-${newStatus.replace(' ', '-')} status-editable`;
                        pill.textContent = newStatus;
                        card.setAttribute('data-status', newStatus);

                        // Update the onclick param to hold the new status
                        pill.setAttribute('onclick', `openStatusModal('${tripId}', '${newStatus}')`);

                        // Small bounce effect on update
                        pill.animate([
                            { transform: 'scale(1)' },
                            { transform: 'scale(1.15)' },
                            { transform: 'scale(1)' }
                        ], { duration: 300, easing: 'ease-in-out' });
                    }

                    // Global ping
                    if (typeof window.triggerDashboardTripUpdate === 'function') {
                        window.triggerDashboardTripUpdate();
                    }

                } else {
                    alert(data.message || 'Failed to update status.');
                }
            })
            .catch(err => alert('Network error.'));
        }
    </script>
}