@using System.Text.Encodings.Web
@using PUBReservationSystem.Models
@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";

    // ✅ FIXED: Direct case-insensitive session evaluation bypasses any controller ViewBag gaps
    var currentRole = Context.Session.GetString("Role") ?? ViewBag.Role as string ?? "";
    var isAdmin = currentRole.Equals("Admin", StringComparison.OrdinalIgnoreCase) ||
                  currentRole.Equals("SuperAdmin", StringComparison.OrdinalIgnoreCase);
}

<style>
    /* ===================== ANIMATIONS ===================== */
    @@keyframes pageEnter {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes rowSlideIn {
        from {
            opacity: 0;
            transform: translateX(-10px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes modalFadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes modalFadeOut {
        from {
            opacity: 1;
        }

        to {
            opacity: 0;
        }
    }

    @@keyframes modalPopIn {
        from {
            transform: scale(0.95) translateY(20px);
            opacity: 0;
        }

        to {
            transform: scale(1) translateY(0);
            opacity: 1;
        }
    }

    @@keyframes modalPopOut {
        from {
            transform: scale(1) translateY(0);
            opacity: 1;
        }

        to {
            transform: scale(0.95) translateY(20px);
            opacity: 0;
        }
    }

    .page-header {
        animation: pageEnter 0.4s 0.05s both;
    }

    .sys-alert-banner {
        animation: pageEnter 0.4s 0.10s both;
    }

    .filter-toolbar-card {
        animation: pageEnter 0.4s 0.15s both;
    }

    .sys-card {
        animation: pageEnter 0.5s cubic-bezier(0.22,1,0.36,1) 0.20s both;
    }

    table.sys-table tbody tr {
        animation: rowSlideIn 0.35s cubic-bezier(0.22,1,0.36,1) both;
    }

    tbody tr:nth-child(1) {
        animation-delay: 0.05s;
    }

    tbody tr:nth-child(2) {
        animation-delay: 0.10s;
    }

    tbody tr:nth-child(3) {
        animation-delay: 0.15s;
    }

    tbody tr:nth-child(4) {
        animation-delay: 0.20s;
    }

    tbody tr:nth-child(5) {
        animation-delay: 0.25s;
    }

    /* ===================== LAYOUT & GENERAL UI ===================== */
    .res-layout-wrap {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .sys-alert-banner {
        padding: 14px 20px;
        border-radius: var(--radius-sm, 8px);
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: var(--shadow-xs);
        background: var(--navy-50, #eff6ff);
        color: var(--navy-700, #1e3a8a);
        border-left: 4px solid var(--accent, #3b6cf7);
        margin-bottom: 20px;
    }

        .sys-alert-banner i {
            font-size: 16px;
            color: var(--accent, #3b6cf7);
        }

    .sys-card {
        background: white;
        border-radius: var(--radius-lg, 16px);
        box-shadow: 0 4px 12px rgba(15,28,63,0.04);
        border: 1px solid var(--border, #e2e8f0);
        overflow: hidden;
    }

    .sys-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border, #e2e8f0);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: white;
    }

    .sys-card-title {
        font-size: 14.5px;
        font-weight: 700;
        color: var(--navy-800, #0f1c3f);
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0;
    }

    .sys-count-badge {
        background: var(--accent-soft, #e8eeff);
        color: var(--accent, #3b6cf7);
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 12px;
    }

    /* ===================== STATUS PILLS ===================== */
    .res-status-pill {
        font-size: 10px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-active {
        background: var(--green-soft, #e3f9f1);
        color: var(--green, #0fa66e);
        border: 1px solid rgba(15,166,110,0.2);
    }

    .status-locked {
        background: var(--red-soft, #fdeaea);
        color: var(--red, #e0413a);
        border: 1px solid rgba(224,65,58,0.2);
    }

    .status-inactive {
        background: #fff3e0;
        color: #e65100;
        border: 1px solid rgba(230,81,0,0.2);
    }

    /* ===================== TABLE ===================== */
    .sys-table-wrap {
        overflow-x: auto;
        overflow-y: hidden;
        width: 100%;
        padding-bottom: 8px;
    }

        .sys-table-wrap::-webkit-scrollbar {
            height: 8px;
        }

        .sys-table-wrap::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 10px;
        }

        .sys-table-wrap::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

            .sys-table-wrap::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

    table.sys-table {
        white-space: nowrap;
        min-width: 1000px;
        border-collapse: collapse;
        width: 100%;
    }

        table.sys-table th, table.sys-table td {
            padding: 13px 16px;
            border-bottom: 1px solid var(--border, #e2e8f0);
            font-size: 13px;
        }

        table.sys-table thead th {
            background: #f8fafd;
            color: var(--text-muted, #94a3b8);
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            text-align: left;
        }

        table.sys-table tbody tr {
            transition: background 0.15s;
        }

            table.sys-table tbody tr:hover td {
                background: #f0f4ff;
            }

            table.sys-table tbody tr:last-child td {
                border-bottom: none;
            }

    .ref-id-text {
        font-weight: 700;
        color: var(--accent, #3b6cf7);
        font-size: 12px;
    }

    .sticky-action-col {
        position: sticky;
        right: 0;
        z-index: 2;
        background: #fff;
        box-shadow: -4px 0 12px rgba(15,28,63,0.04);
    }

    table.sys-table thead th.sticky-action-col {
        background: #f8fafd;
        z-index: 3;
        text-align: center;
    }

    table.sys-table tbody tr:hover td.sticky-action-col {
        background: #f0f4ff;
    }

    /* Action Icons */
    .action-group {
        display: flex;
        gap: 6px;
        justify-content: center;
    }

    .btn-action-icon {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 12px;
    }

    .icon-unlock {
        background: #fff3e0;
        color: #e65100;
    }

        .icon-unlock:hover {
            background: #e65100;
            color: white;
            transform: translateY(-2px);
        }

    .icon-deactivate {
        background: #fff3e0;
        color: #ff9800;
    }

        .icon-deactivate:hover {
            background: #ff9800;
            color: white;
            transform: translateY(-2px);
        }

    .icon-activate {
        background: #e8f5e9;
        color: #2e7d32;
    }

        .icon-activate:hover {
            background: #2e7d32;
            color: white;
            transform: translateY(-2px);
        }

    .icon-delete {
        background: #ffebee;
        color: #c62828;
    }

        .icon-delete:hover {
            background: #c62828;
            color: white;
            transform: translateY(-2px);
        }

    /* ===================== MODALS ===================== */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,28,63,0.6);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(3px);
    }

        .modal-overlay.show {
            display: flex;
            animation: modalFadeIn 0.25s ease-out forwards;
        }

        .modal-overlay.hide {
            animation: modalFadeOut 0.2s ease-in forwards;
        }

    .sys-modal {
        background: white;
        border-radius: var(--radius-lg, 16px);
        width: 90%;
        max-width: 500px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        display: flex;
        flex-direction: column;
    }

    .modal-overlay.show .sys-modal {
        animation: modalPopIn 0.3s cubic-bezier(0.175,0.885,0.32,1.275) forwards;
    }

    .modal-overlay.hide .sys-modal {
        animation: modalPopOut 0.2s ease-in forwards;
    }

    .modal-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border, #e2e8f0);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header h4 {
            margin: 0;
            font-size: 16px;
            font-weight: 700;
            color: var(--navy-800, #0f1c3f);
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .btn-close-modal {
        background: none;
        border: none;
        font-size: 20px;
        color: var(--text-muted);
        cursor: pointer;
        transition: color 0.2s;
    }

        .btn-close-modal:hover {
            color: var(--red, #e0413a);
        }

    .modal-body {
        padding: 24px;
        flex: 1;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border, #e2e8f0);
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        background: #f8fafd;
        border-radius: 0 0 var(--radius-lg, 16px) var(--radius-lg, 16px);
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-row {
        display: flex;
        gap: 16px;
    }

        .form-row .form-group {
            flex: 1;
        }

    .form-group label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

        .form-group label.required::after {
            content: " *";
            color: var(--red, #e0413a);
            font-weight: bold;
        }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid var(--border, #e2e8f0);
        border-radius: 8px;
        font-size: 13.5px;
        font-family: 'Inter', sans-serif;
        transition: border-color 0.2s;
    }

        .form-control:focus {
            border-color: var(--accent, #3b6cf7);
            outline: none;
            box-shadow: 0 0 0 3px rgba(59,108,247,0.1);
        }

    .password-hint {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 6px;
    }

    /* Action Modal Adjustments */
    .action-warning-box {
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 13px;
        font-weight: 500;
    }

    .action-details-box {
        background: #f8fafd;
        border: 1px solid var(--border, #e2e8f0);
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        padding: 6px 0;
        border-bottom: 1px dashed var(--border, #e2e8f0);
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        color: var(--text-secondary);
        font-weight: 600;
    }

    .detail-val {
        color: var(--navy-800, #0f1c3f);
        font-weight: 700;
    }
</style>

@* PAGE HEADER *@
<div class="page-header" style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px;">
    <div>
        <h2 style="font-size:20px; font-weight:800; color:var(--navy-800,#0f1c3f); margin:0; display:flex; align-items:center; gap:10px;">
            <i class="fas fa-user-cog" style="color:var(--accent);"></i> User Management
        </h2>
        <p style="font-size:13px; color:var(--text-secondary); margin:3px 0 0;">
            Manage system access, operator roles, and account statuses
        </p>
    </div>
    <div style="display:flex; align-items:center; gap:8px;">
        <button class="btn-primary-sys" onclick="openModal('createUserModal')">
            <i class="fas fa-plus-circle"></i> Create New Account
        </button>
    </div>
</div>

@* ADMIN BANNER *@
<div class="sys-alert-banner">
    <i class="fas fa-shield-alt"></i>
    <span><strong>Security Notice:</strong> Administrative actions are strictly logged. Ensure role assignments comply with company operational policies.</span>
</div>

<div class="res-layout-wrap">
    @* USERS TABLE *@
    <div class="sys-card">
        <div class="sys-card-header">
            <h5 class="sys-card-title"><i class="fas fa-users"></i> System Accounts</h5>
            <span class="sys-count-badge">
                @(ViewBag.Users != null ? ((List<Users>)ViewBag.Users).Count : 0) registered
            </span>
        </div>
        <div class="sys-table-wrap">
            <table class="sys-table">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Role</th>
                        <th style="text-align:center;">Status</th>
                        <th>Last Login</th>
                        <th class="sticky-action-col">Actions</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    @if (ViewBag.Users != null)
                    {
                        foreach (var user in (List<Users>)ViewBag.Users)
                        {
                            <tr data-userid="@user.User_ID">
                                <td class="ref-id-text">@user.User_ID.ToString("D5")</td>
                                <td style="font-weight:600; color:var(--navy-800,#0f1c3f);">@user.Username</td>
                                <td style="font-weight:500;">@(user.Employee?.Full_Name ?? "N/A")</td>
                                <td><span style="font-size:12px; font-weight:600; color:var(--text-secondary);">@user.Role</span></td>
                                <td style="text-align:center;">
                                    @if (user.Account_Locked)
                                    {
                                        <span class="res-status-pill status-locked">Locked</span>
                                    }
                                    else if (user.Is_Active)
                                    {
                                        <span class="res-status-pill status-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="res-status-pill status-inactive">Deactivated</span>
                                    }
                                </td>
                                <td style="color:var(--text-secondary); font-size:12px;">
                                    @(user.Last_Login?.ToString("MMM dd, yyyy hh:mm tt") ?? "Never")
                                </td>
                                <td class="sticky-action-col">
                                    <div class="action-group">
                                        @if (user.Account_Locked && isAdmin)
                                        {
                                            <button class="btn-action-icon icon-unlock" title="Unlock Account"
                                                    onclick="openActionModal('unlockModal', @user.User_ID, '@JavaScriptEncoder.Default.Encode(user.Employee?.Full_Name ?? "N/A")', '@JavaScriptEncoder.Default.Encode(user.Username)', '@JavaScriptEncoder.Default.Encode(user.Role)')">
                                                <i class="fas fa-lock-open"></i>
                                            </button>
                                        }
                                        @if (!user.Account_Locked && user.Is_Active && isAdmin)
                                        {
                                            <button class="btn-action-icon icon-deactivate" title="Deactivate Account"
                                                    onclick="openActionModal('deactivateModal', @user.User_ID, '@JavaScriptEncoder.Default.Encode(user.Employee?.Full_Name ?? "N/A")', '@JavaScriptEncoder.Default.Encode(user.Username)', '@JavaScriptEncoder.Default.Encode(user.Role)')">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        }
                                        @if (!user.Account_Locked && !user.Is_Active && isAdmin)
                                        {
                                            <button class="btn-action-icon icon-activate" title="Activate Account"
                                                    onclick="openActionModal('activateModal', @user.User_ID, '@JavaScriptEncoder.Default.Encode(user.Employee?.Full_Name ?? "N/A")', '@JavaScriptEncoder.Default.Encode(user.Username)', '@JavaScriptEncoder.Default.Encode(user.Role)')">
                                                <i class="fas fa-check-circle"></i>
                                            </button>
                                        }
                                        <button class="btn-action-icon icon-delete" title="Delete User"
                                                onclick="openActionModal('deleteModal', @user.User_ID, '@JavaScriptEncoder.Default.Encode(user.Employee?.Full_Name ?? "N/A")', '@JavaScriptEncoder.Default.Encode(user.Username)', '@JavaScriptEncoder.Default.Encode(user.Role)')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ===== MODAL 1: CREATE USER (2x2 GRID) ===== *@
<div id="createUserModal" class="modal-overlay">
    <div class="sys-modal" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4><i class="fas fa-user-plus" style="color:var(--accent);"></i> Create New Account</h4>
            <button class="btn-close-modal" onclick="closeModal('createUserModal')"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="required">Employee ID</label>
                    <div style="display:flex; gap:8px;">
                        <input type="text" id="newEmpId" class="form-control" placeholder="e.g., EMP-1024" onblur="simulateEmployeeVerify()">
                        <button class="btn-primary-sys" style="padding: 10px 14px;" onclick="simulateEmployeeVerify()">Verify</button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="required">Full Name</label>
                    <input type="text" id="newName" class="form-control" placeholder="Juan Dela Cruz" readonly style="background:#f8fafd;">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="required">Role</label>
                    <select id="newRole" class="form-control">
                        <option value="">Select Role...</option>
                        <option value="Admin">Admin</option>
                        <option value="HeadTeller">Head Teller</option>
                        <option value="Teller">Teller</option>
                        <option value="Dispatcher">Dispatcher</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="required">Branch Assignment</label>
                    <select id="branchAssignment" name="Branch_ID" class="form-control" required>
                        <option value="">Select Branch...</option>
                        @if (ViewBag.Branches != null)
                        {
                            @foreach (var branch in (List<PUBReservationSystem.Models.Branch>)ViewBag.Branches)
                            {
                                // Use the ID as the value, display the Name as the text
                                <option value="@branch.Branch_ID">@branch.Branch_Name</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="required">Username</label>
                <input type="text" id="newUsername" class="form-control" placeholder="e.g., juan.dela.cruz" maxlength="50">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="required">Password</label>
                    <input type="password" id="newPassword" class="form-control" placeholder="Enter password">
                </div>
                <div class="form-group">
                    <label class="required">Confirm Password</label>
                    <input type="password" id="confirmPassword" class="form-control" placeholder="Re-enter password">
                </div>
            </div>
            <div class="password-hint" style="margin-top:-10px; margin-bottom:10px;">Min 8 chars, 1 uppercase, 1 number</div>
        </div>
        <div class="modal-footer">
            <button class="btn-ghost-sys" onclick="closeModal('createUserModal')">Cancel</button>
            <button class="btn-primary-sys" id="btnSaveNewUser" onclick="saveUser()">
                <i class="fas fa-save"></i> Create Account
            </button>
        </div>
    </div>
</div>

@* ===== MODAL 2: UNLOCK USER ===== *@
<div id="unlockModal" class="modal-overlay">
    <div class="sys-modal" onclick="event.stopPropagation()" style="max-width:420px;">
        <div class="modal-header" style="border-bottom-color: rgba(230,81,0,0.2);">
            <h4 style="color:#e65100;"><i class="fas fa-lock-open"></i> Unlock User Account</h4>
            <button class="btn-close-modal" onclick="closeModal('unlockModal')"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="action-warning-box" style="background:#fff3e0; color:#e65100; border-left:4px solid #e65100;">
                Are you sure you want to unlock this account? The user will be able to log in immediately.
            </div>
            <div class="action-details-box">
                <div class="detail-row"><span class="detail-label">Name</span><span class="detail-val" id="unlockFullName">--</span></div>
                <div class="detail-row"><span class="detail-label">Username</span><span class="detail-val" id="unlockUsername">--</span></div>
                <div class="detail-row"><span class="detail-label">Role</span><span class="detail-val" id="unlockRole">--</span></div>
            </div>
            <input type="hidden" id="unlockTargetId">
        </div>
        <div class="modal-footer">
            <button class="btn-ghost-sys" onclick="closeModal('unlockModal')">Cancel</button>
            <button class="btn-primary-sys" style="background:#ff9800;" onclick="confirmUnlock()">Confirm Unlock</button>
        </div>
    </div>
</div>

@* ===== MODAL 3: DEACTIVATE USER ===== *@
<div id="deactivateModal" class="modal-overlay">
    <div class="sys-modal" onclick="event.stopPropagation()" style="max-width:420px;">
        <div class="modal-header" style="border-bottom-color: rgba(230,81,0,0.2);">
            <h4 style="color:#e65100;"><i class="fas fa-user-slash"></i> Deactivate Account</h4>
            <button class="btn-close-modal" onclick="closeModal('deactivateModal')"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="action-warning-box" style="background:#fff3e0; color:#e65100; border-left:4px solid #e65100;">
                This account will be suspended. The user will be immediately logged out if currently active.
            </div>
            <div class="action-details-box">
                <div class="detail-row"><span class="detail-label">Name</span><span class="detail-val" id="deactivateFullName">--</span></div>
                <div class="detail-row"><span class="detail-label">Username</span><span class="detail-val" id="deactivateUsername">--</span></div>
                <div class="detail-row"><span class="detail-label">Role</span><span class="detail-val" id="deactivateRole">--</span></div>
            </div>
            <input type="hidden" id="deactivateTargetId">
        </div>
        <div class="modal-footer">
            <button class="btn-ghost-sys" onclick="closeModal('deactivateModal')">Cancel</button>
            <button class="btn-primary-sys" style="background:#e65100;" onclick="confirmDeactivate()">Deactivate</button>
        </div>
    </div>
</div>

@* ===== MODAL 4: ACTIVATE USER ===== *@
<div id="activateModal" class="modal-overlay">
    <div class="sys-modal" onclick="event.stopPropagation()" style="max-width:420px;">
        <div class="modal-header" style="border-bottom-color: rgba(15,166,110,0.2);">
            <h4 style="color:var(--green,#0fa66e);"><i class="fas fa-check-circle"></i> Activate Account</h4>
            <button class="btn-close-modal" onclick="closeModal('activateModal')"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="action-warning-box" style="background:var(--green-soft,#e3f9f1); color:var(--green,#0fa66e); border-left:4px solid var(--green,#0fa66e);">
                Restore access? This account will regain all system privileges assigned to its role.
            </div>
            <div class="action-details-box">
                <div class="detail-row"><span class="detail-label">Name</span><span class="detail-val" id="activateFullName">--</span></div>
                <div class="detail-row"><span class="detail-label">Username</span><span class="detail-val" id="activateUsername">--</span></div>
                <div class="detail-row"><span class="detail-label">Role</span><span class="detail-val" id="activateRole">--</span></div>
            </div>
            <input type="hidden" id="activateTargetId">
        </div>
        <div class="modal-footer">
            <button class="btn-ghost-sys" onclick="closeModal('activateModal')">Cancel</button>
            <button class="btn-primary-sys" style="background:var(--green,#0fa66e);" onclick="confirmActivate()">Activate User</button>
        </div>
    </div>
</div>

@* ===== MODAL 5: DELETE USER ===== *@
<div id="deleteModal" class="modal-overlay">
    <div class="sys-modal" onclick="event.stopPropagation()" style="max-width:420px;">
        <div class="modal-header" style="border-bottom-color: rgba(224,65,58,0.2);">
            <h4 style="color:var(--red,#e0413a);"><i class="fas fa-trash-alt"></i> Delete Account</h4>
            <button class="btn-close-modal" onclick="closeModal('deleteModal')"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="action-warning-box" style="background:var(--red-soft,#fdeaea); color:var(--red,#e0413a); border-left:4px solid var(--red,#e0413a);">
                <i class="fas fa-exclamation-triangle"></i> This action is permanent and cannot be undone. All data tied directly to this login will be cleared.
            </div>
            <div class="action-details-box">
                <div class="detail-row"><span class="detail-label">Name</span><span class="detail-val" id="deleteFullName">--</span></div>
                <div class="detail-row"><span class="detail-label">Username</span><span class="detail-val" id="deleteUsername">--</span></div>
                <div class="detail-row"><span class="detail-label">Role</span><span class="detail-val" id="deleteRole">--</span></div>
            </div>
            <input type="hidden" id="deleteTargetId">
        </div>
        <div class="modal-footer">
            <button class="btn-ghost-sys" onclick="closeModal('deleteModal')">Cancel</button>
            <button class="btn-danger-sys" onclick="confirmDelete()">Delete Account</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ========== HELPER FUNCTIONS ==========
        function escapeHtml(text) {
            if (!text) return '';
            var div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ========== TOAST NOTIFICATION ENGINE ==========
        function showToast(message, type) {
            var existingToast = document.querySelector('.toast-notification');
            if (existingToast) existingToast.remove();

            var toast = document.createElement('div');
            toast.className = 'toast-notification';

            if (type === 'error') {
                toast.classList.add('error');
                toast.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + message;
            } else if (type === 'warning') {
                toast.classList.add('warning');
                toast.innerHTML = '<i class="fas fa-exclamation-triangle"></i> ' + message;
            } else {
                toast.innerHTML = '<i class="fas fa-check-circle"></i> ' + message;
            }

            document.body.appendChild(toast);
            void toast.offsetWidth; // Force reflow
            toast.classList.add('active');

            var hideTimeout = setTimeout(function () {
                if (toast) {
                    toast.classList.remove('active');
                    toast.classList.add('closing');
                    setTimeout(function () { if (toast) toast.remove(); }, 400);
                }
            }, 3500);

            toast.onclick = function () {
                clearTimeout(hideTimeout);
                toast.classList.remove('active');
                toast.classList.add('closing');
                setTimeout(function () { if (toast) toast.remove(); }, 400);
            };
        }

        // ========== MODAL CONTROLLER ==========
        function openModal(modalId, data) {
            var modal = document.getElementById(modalId);
            if (!modal) return;

            // Reset the form if it's the Create User Modal
            if (modalId === 'createUserModal') {
                document.getElementById('newEmpId').value = '';
                document.getElementById('newName').value = '';
                document.getElementById('newName').readOnly = true;
                document.getElementById('newRole').value = '';
                document.getElementById('branchAssignment').value = '';
                document.getElementById('newUsername').value = '';
                document.getElementById('newPassword').value = '';
                document.getElementById('confirmPassword').value = '';
            }

            // Action Modals Data & Theme Binding
            if (data && modalId !== 'createUserModal') {
                var prefix = modalId.replace('Modal', '');

                var fullNameSpan = document.getElementById(prefix + 'FullName');
                var usernameSpan = document.getElementById(prefix + 'Username');
                var roleSpan = document.getElementById(prefix + 'Role');

                if (fullNameSpan) fullNameSpan.textContent = data.fullName || 'N/A';
                if (usernameSpan) usernameSpan.textContent = data.username || 'N/A';
                if (roleSpan) roleSpan.textContent = data.role || 'N/A';
            }

            // Animate In
            modal.classList.remove('hide');
            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            var modal = document.getElementById(modalId);
            if (!modal) return;

            modal.classList.remove('show');
            modal.classList.add('hide');

            setTimeout(function () {
                modal.classList.remove('hide');
                if (!document.querySelector('.modal-overlay.show')) {
                    document.body.style.overflow = '';
                }
            }, 220); // Syncs with CSS animation duration
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                var open = document.querySelectorAll('.modal-overlay.show');
                if (open.length) closeModal(open[open.length - 1].id);
            }
        });

        // ========== INPUT VALIDATION & LOGIC ==========

        // Strict Name Validation: Letters only, Auto Title Case
        document.getElementById('newName').addEventListener('input', function(e) {
            var cleanString = e.target.value.replace(/[^a-zA-Z\s]/g, '');
            e.target.value = cleanString.replace(/\b\w/g, function(char) { return char.toUpperCase(); });
        });

        // Employee Verification Simulation
        function simulateEmployeeVerify() {
            var empId = document.getElementById('newEmpId').value.trim();
            if (!empId) {
                showToast('Please enter an Employee ID to verify.', 'warning');
                return;
            }

            // Mock verification (In reality, do an AJAX fetch here)
            showToast('Verifying employee record...', 'success');

            setTimeout(function() {
                var nameInput = document.getElementById('newName');
                nameInput.readOnly = false; // Unlock field
                nameInput.style.background = '#fff';
                nameInput.focus();
                showToast('Employee verified. Please enter their full name.', 'success');
            }, 600);
        }

        // ========== CREATE USER (DYNAMIC ROW INSERTION) ==========
        // ========== CREATE USER (DYNAMIC ROW INSERTION - FIXED) ==========
        function saveUser() {
            // 1. Get values from the form
            var empId = document.getElementById('newEmpId').value.trim();
            var role = document.getElementById('newRole').value;
            var branchId = document.getElementById('branchAssignment').value;
            var username = document.getElementById('newUsername').value.trim();
            var pass = document.getElementById('newPassword').value;
            var conf = document.getElementById('confirmPassword').value;

            // 2. Frontend Validation
            if (!empId || !role || !branchId || !username || !pass) {
                showToast('Please fill in all required fields (including Branch).', 'warning');
                return;
            }

            if (pass !== conf) {
                showToast('Passwords do not match.', 'error');
                return;
            }

            // 3. UI Loading State
            var btn = document.getElementById('btnSaveNewUser');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

            // 4. Prepare Data for C# Method
            var formData = new URLSearchParams();
            formData.append('username', username);
            formData.append('password', pass);
            formData.append('role', role);
            formData.append('employeeId', empId);

            // ✅ FIX 2: Double-bind both naming conventions to guarantee cross-branch authorization validation pass
            formData.append('branchId', branchId);
            formData.append('branchAssignment', branchId);

            // 5. Send POST request
            fetch('/Home/SaveUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            })
            .then(function(response) {
                return response.json();
            })
            .then(function(data) {
                if (data.success) {
                    var newUserData = {
                        userId: data.userId,
                        username: username,
                        fullName: data.fullName,
                        role: role
                    };

                    insertNewUserRow(newUserData);
                    showToast(data.message, 'success');
                    closeModal('createUserModal');
                } else {
                    showToast(data.message, 'error');
                }
            })
            .catch(function(error) {
                console.error("Save error:", error);
                showToast('A server error occurred while saving.', 'error');
            })
            .finally(function() {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save"></i> Create Account';
            });
        }

        function insertNewUserRow(data) {
            var tbody = document.getElementById('userTableBody');

            if (!tbody) {
                console.error("Could not find the table body with ID 'userTableBody'. Row insertion failed.");
                return;
            }

            var emptyRow = tbody.querySelector('.empty-state');
            if (emptyRow) {
                tbody.innerHTML = '';
            }

            var tr = document.createElement('tr');
            tr.setAttribute('data-userid', data.userId);

            tr.style.animation = 'rowSlideIn 0.4s cubic-bezier(0.22,1,0.36,1) forwards';
            tr.style.backgroundColor = '#e8eeff';

            var escId = data.userId;
            var escName = escapeHtml(data.fullName);
            var escUser = escapeHtml(data.username);
            var escRole = escapeHtml(data.role);

            // ✅ FIX 1: Added missing 'Never' login log data column to preserve structural cell indexes (7 columns total)
            tr.innerHTML = `
                <td class="ref-id-text">${data.userId.toString().padStart(5, '0')}</td>
                <td style="font-weight:600; color:var(--navy-800,#0f1c3f);">${escUser}</td>
                <td style="font-weight:500;">${escName}</td>
                <td><span style="font-size:12px; font-weight:600; color:var(--text-secondary);">${escRole}</span></td>
                <td style="text-align:center;"><span class="res-status-pill status-active">Active</span></td>
                <td style="color:var(--text-secondary); font-size:12px;">Never</td>
                <td class="sticky-action-col">
                    <div class="action-group">
                        <button class="btn-action-icon icon-deactivate" title="Deactivate Account"
                                onclick="openActionModal('deactivateModal', ${escId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-ban"></i>
                        </button>
                        <button class="btn-action-icon icon-delete" title="Delete User"
                                onclick="openActionModal('deleteModal', ${escId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </td>
            `;

            tbody.insertBefore(tr, tbody.firstChild);

            setTimeout(function() {
                tr.style.transition = 'background-color 1s ease';
                tr.style.backgroundColor = 'transparent';
            }, 1500);
        }

        // ========== ACTION MODAL HANDLERS (ACTIVATE / DEACTIVATE / DELETE / UNLOCK) ==========
        var currentTargetId = null;

        function openActionModal(modalId, id, name, username, role) {
            currentTargetId = id;
            openModal(modalId, { fullName: name, username: username, role: role });
        }

        function confirmDeactivate() {
            if (!currentTargetId) return;
            var targetId = currentTargetId;

            var formData = new URLSearchParams();
            formData.append('userId', targetId);

            fetch('/Home/DeactivateUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message || 'Account suspended successfully.', 'success');
                    updateUserRow(targetId, 'deactivated'); // ⚡ Surgical single-row update
                    closeModal('deactivateModal');
                } else {
                    showToast(data.message || 'Failed to deactivate account.', 'error');
                }
            })
            .catch(err => console.error("Database error:", err));
        }

        function confirmActivate() {
            if (!currentTargetId) return;
            var targetId = currentTargetId;

            var formData = new URLSearchParams();
            formData.append('userId', targetId);

            fetch('/Home/ActivateUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message || 'Account privileges restored.', 'success');
                    updateUserRow(targetId, 'activated'); // ⚡ Surgical single-row update
                    closeModal('activateModal');
                } else {
                    showToast(data.message || 'Failed to activate account.', 'error');
                }
            })
            .catch(err => console.error("Database error:", err));
        }

                function confirmUnlock() {
            if (!currentTargetId) return;
            var targetId = currentTargetId;

            var formData = new URLSearchParams();
            formData.append('userId', targetId);

            fetch('/Home/UnlockUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message || 'Account unlocked successfully.', 'success');
                    updateUserRow(targetId, 'activated'); // ⚡ Surgical single-row update
                    closeModal('unlockModal');
                } else {
                    showToast(data.message || 'Failed to unlock account.', 'error');
                }
            })
            .catch(err => console.error("Database error:", err));
        }

                function confirmDelete() {
            if (!currentTargetId) return;
            var targetId = currentTargetId;

            var formData = new URLSearchParams();
            formData.append('userId', targetId);

            fetch('/Home/DeleteUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message || 'User account purged from database.', 'success');
                    removeUserRow(targetId); // ⚡ Surgical row drop-out animation
                    closeModal('deleteModal');

                    // Optional: Decrement the total counter badge text dynamically
                    var badge = document.querySelector('.sys-count-badge');
                    if (badge) {
                        var currentCount = parseInt(badge.textContent) || 0;
                        if (currentCount > 0) badge.textContent = (currentCount - 1) + " registered";
                    }
                } else {
                    showToast(data.message || 'Failed to delete account.', 'error');
                }
            })
            .catch(err => console.error("Database error:", err));
        }

                // ✅ FIXED: Standardized row manipulator to handle live 'locked' status updates seamlessly
        function updateUserRow(userId, action) {
            var row = document.querySelector(`#userTableBody tr[data-userid="${userId}"]`);
            if (!row) return;

            // Extract text safely from adjacent cells to rebuild click handlers without data loss
            var username = row.cells[1].textContent.trim();
            var fullName = row.cells[2].textContent.trim();
            var role = row.cells[3].textContent.trim();

            // Clean escaping wrappers to safeguard quotes in employee names
            var escName = escapeHtml(fullName);
            var escUser = escapeHtml(username);
            var escRole = escapeHtml(role);

            row.style.transition = 'all 0.4s ease';

            if (action === 'locked' || action === 'LOCKED') {
                // 1. Render the correct deep red status pill badge
                row.cells[4].innerHTML = '<span class="res-status-pill status-locked">Locked</span>';

                // 2. Re-inject styled action buttons with perfect CSS class references and modal triggers
                row.cells[6].innerHTML = `
                    <div class="action-group">
                        <button class="btn-action-icon icon-unlock" title="Unlock Account"
                                onclick="openActionModal('unlockModal', ${userId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-lock-open"></i>
                        </button>
                        <button class="btn-action-icon icon-delete" title="Delete User"
                                onclick="openActionModal('deleteModal', ${userId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `;
                // Soft red background flash to draw immediate admin attention to the lockout
                row.style.backgroundColor = '#fdeaea';
            }
            else if (action === 'deactivated') {
                row.cells[4].innerHTML = '<span class="res-status-pill status-inactive">Deactivated</span>';
                row.cells[6].innerHTML = `
                    <div class="action-group">
                        <button class="btn-action-icon icon-activate" title="Activate Account"
                                onclick="openActionModal('activateModal', ${userId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-check-circle"></i>
                        </button>
                        <button class="btn-action-icon icon-delete" title="Delete User"
                                onclick="openActionModal('deleteModal', ${userId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `;
                row.style.backgroundColor = '#fff3e0';
            }
            else if (action === 'activated' || action === 'unlocked') {
                row.cells[4].innerHTML = '<span class="res-status-pill status-active">Active</span>';
                row.cells[6].innerHTML = `
                    <div class="action-group">
                        <button class="btn-action-icon icon-deactivate" title="Deactivate Account"
                                onclick="openActionModal('deactivateModal', ${userId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-ban"></i>
                        </button>
                        <button class="btn-action-icon icon-delete" title="Delete User"
                                onclick="openActionModal('deleteModal', ${userId}, '${escName}', '${escUser}', '${escRole}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `;
                row.style.backgroundColor = '#e8f5e9';
            }

            // Smoothly fade back out to default table transparent backgrounds after regular interval loops
            setTimeout(function () {
                if (row) row.style.backgroundColor = '';
            }, 1500);
        }

        function removeUserRow(userId) {
            var row = document.querySelector(`#userTableBody tr[data-userid="${userId}"]`);
            if (!row) return;

            row.style.transition = 'all 0.3s ease';
            row.style.backgroundColor = '#ffebee';
            row.style.opacity = '0';
            row.style.transform = 'translateX(30px)';

            setTimeout(function () {
                if (row) row.remove();
                var tbody = document.getElementById('userTableBody');
                if (tbody && tbody.querySelectorAll('tr').length === 0) {
                    tbody.innerHTML = '<tr class="empty-state"><td colspan="7" style="text-align:center; padding:40px; color:var(--text-muted);">No user accounts found.</td></tr>';
                }
            }, 300);
        }
    </script>
    

}
