@{
    ViewData["Title"] = "Employee Management";

    // Fetch the role directly from the session
    var role = Context.Session.GetString("Role") ?? "";
    bool isAdmin = role == "Admin";
}

<style>
    /* =========================================
           1. PAGE LOAD ANIMATIONS
           ========================================= */
    @@keyframes pageEnter {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeSlideUp {
        0% {
            opacity: 0;
            transform: translateY(15px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes rowSlideIn {
        from {
            opacity: 0;
            transform: translateX(-10px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .page-header {
        animation: pageEnter 0.4s 0.05s both;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 20px;
    }

    .page-header-left h2.page-title {
        font-size: 24px;
        color: var(--navy-800);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .page-header-left .page-sub {
        color: var(--text-secondary);
        font-size: 14px;
        font-weight: 500;
        margin: 0;
    }

    /* =========================================
           2. LAYOUT & SPACING (20px Dashboard Gap)
           ========================================= */
    .res-layout-wrap {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* =========================================
           3. DASHBOARD STAT CARDS
           ========================================= */
    .stats-grid-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .dash-style-card {
        background: var(--surface, #ffffff);
        border-radius: 10px;
        padding: 22px 20px;
        display: flex;
        align-items: center;
        box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
        border: 1px solid var(--border, #e2e8f0);
        position: relative;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        opacity: 0;
        transform: translateY(15px);
        animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

        .dash-style-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .dash-style-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .dash-style-card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .dash-style-card:nth-child(4) {
            animation-delay: 0.4s;
        }

        .dash-style-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            transition: height 0.3s ease;
        }

        .dash-style-card.card-blue::before {
            background: var(--accent, #3b82f6);
        }

        .dash-style-card.card-green::before {
            background: var(--green, #10b981);
        }

        .dash-style-card.card-orange::before {
            background: var(--orange, #f59e0b);
        }

        .dash-style-card.card-purple::before {
            background: var(--purple, #8b5cf6);
        }

        .dash-style-card:hover {
            transform: translateY(-5px);
            border-color: transparent;
        }

        .dash-style-card.card-blue:hover {
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.12);
        }

        .dash-style-card.card-green:hover {
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.12);
        }

        .dash-style-card.card-orange:hover {
            box-shadow: 0 10px 20px rgba(245, 158, 11, 0.12);
        }

        .dash-style-card.card-purple:hover {
            box-shadow: 0 10px 20px rgba(139, 92, 246, 0.12);
        }

    .stat-icon-wrapper {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-right: 18px;
        flex-shrink: 0;
    }

    .icon-blue {
        background: var(--navy-50, #eff6ff);
        color: var(--accent, #3b82f6);
    }

    .icon-green {
        background: #ecfdf5;
        color: var(--green, #10b981);
    }

    .icon-orange {
        background: #fffbeb;
        color: var(--orange, #f59e0b);
    }

    .icon-purple {
        background: #f5f3ff;
        color: var(--purple, #8b5cf6);
    }

    .stat-text h3 {
        font-size: 24px;
        font-weight: 800;
        color: var(--navy-800, #0f1c3f);
        margin: 0 0 4px 0;
        line-height: 1;
    }

    .stat-text p {
        margin: 0;
        font-size: 12.5px;
        color: var(--text-secondary, #64748b);
        font-weight: 600;
        text-transform: capitalize;
    }

    /* =========================================
           4. FILTER TOOLBAR
           ========================================= */
    .filter-toolbar-card {
        background: var(--surface, #ffffff);
        padding: 16px 20px;
        border-radius: var(--radius, 12px);
        box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
        border: 1px solid var(--border, #e2e8f0);
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        animation: pageEnter 0.4s 0.20s both;
    }

    .search-group {
        position: relative;
        flex: 1;
        min-width: 220px;
        max-width: 340px;
    }

        .search-group i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 14px;
        }

        .search-group input {
            width: 100%;
            padding: 10px 14px 10px 38px;
            border: 1px solid var(--border, #e2e8f0);
            border-radius: 8px;
            font-size: 13px;
            font-family: inherit;
            font-weight: 500;
            outline: none;
            transition: 0.2s;
        }

            .search-group input:focus {
                border-color: var(--accent, #3b82f6);
                box-shadow: 0 0 0 3px var(--navy-50, #eff6ff);
            }

    .filter-select {
        padding: 10px 14px;
        border: 1px solid var(--border, #e2e8f0);
        border-radius: 8px;
        font-size: 13px;
        font-family: inherit;
        font-weight: 500;
        outline: none;
        width: auto;
        min-width: 140px;
    }

    /* Buttons */
    .btn-ghost-sys {
        background: transparent;
        border: 1px solid var(--border, #e2e8f0);
        color: var(--text-secondary, #64748b);
        padding: 0 16px;
        height: 38px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: all 0.2s;
        font-family: inherit;
    }

        .btn-ghost-sys:hover {
            background: #f1f5f9;
            color: var(--navy-800, #0f1c3f);
        }

    .btn-primary-sys {
        background: var(--navy-800, #0f1c3f);
        color: white;
        padding: 0 18px;
        height: 38px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        font-family: inherit;
    }

        .btn-primary-sys:hover {
            background: var(--accent, #3b82f6);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }

    /* =========================================
           5. TABLE STYLES & ANIMATIONS
           ========================================= */
    .sys-card-table {
        background: var(--surface, #ffffff);
        border-radius: var(--radius-lg, 16px);
        box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
        border: 1px solid var(--border, #e2e8f0);
        overflow: hidden;
        animation: pageEnter 0.5s cubic-bezier(0.22,1,0.36,1) 0.25s both;
    }

    .sys-card-header {
        padding: 16px 22px;
        border-bottom: 1px solid var(--border, #e2e8f0);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
    }

    .table-wrapper {
        overflow-x: auto;
        width: 100%;
    }

    table.sys-table {
        width: 100%;
        border-collapse: collapse;
        white-space: nowrap;
        min-width: 1100px;
    }

        table.sys-table th {
            text-align: left;
            padding: 16px 22px;
            color: var(--text-secondary, #64748b);
            font-size: 11.5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--border, #e2e8f0);
            background: #f8fafc;
            font-weight: 700;
        }

        table.sys-table td {
            padding: 16px 22px;
            font-size: 13.5px;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
            font-weight: 500;
        }

    /* Sticky Action Column */
    .sticky-action-col {
        position: sticky;
        right: 0;
        z-index: 2;
        background: #fff;
        box-shadow: -4px 0 12px rgba(15,28,63,0.04);
    }

    table.sys-table th.sticky-action-col {
        background: #f8fafc;
        z-index: 3;
    }

    table.sys-table tbody tr:hover td.sticky-action-col {
        background: #f8fafc;
    }

    .badge-sys {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 700;
        display: inline-block;
    }

    .badge-green {
        background: #ecfdf5;
        color: var(--green, #10b981);
    }

    .badge-red {
        background: #fef2f2;
        color: #ef4444;
    }

    .action-btn {
        background: transparent;
        border: none;
        padding: 6px;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
    }

        .action-btn.edit {
            color: var(--accent, #3b82f6);
            background: var(--navy-50, #eff6ff);
        }

            .action-btn.edit:hover {
                background: var(--accent, #3b82f6);
                color: white;
            }

        .action-btn.delete {
            color: #ef4444;
            background: #fef2f2;
        }

            .action-btn.delete:hover {
                background: #ef4444;
                color: white;
            }

    /* Row Slide Animations */
    table.sys-table tbody tr {
        animation: rowSlideIn 0.35s cubic-bezier(0.22,1,0.36,1) both;
        opacity: 1;
        transform: translateX(0);
    }

    tbody tr:nth-child(1) {
        animation-delay: 0.05s;
    }

    tbody tr:nth-child(2) {
        animation-delay: 0.10s;
    }

    tbody tr:nth-child(3) {
        animation-delay: 0.15s;
    }

    tbody tr:nth-child(4) {
        animation-delay: 0.20s;
    }

    tbody tr:nth-child(5) {
        animation-delay: 0.25s;
    }

    tbody tr:nth-child(6) {
        animation-delay: 0.30s;
    }

    #employeeTableBody tr.slide-standby {
        opacity: 0;
        transform: translateX(-50px);
    }

    #employeeTableBody tr.hide-row {
        display: none !important;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-secondary, #64748b);
        font-weight: 500;
    }

        .empty-state i {
            font-size: 56px;
            margin-bottom: 15px;
            color: #e2e8f0;
        }

    /* =========================================
           6. MODALS
           ========================================= */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 28, 63, 0.6);
        backdrop-filter: blur(4px);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

        .modal-overlay.active {
            display: flex;
            animation: fadeIn 0.2s ease-out forwards;
        }
    @@keyframes fadeIn {
        0% {
            opacity: 0;
        }

        100% {
            opacity: 1;
        }
    }

    .modal-box {
        background: white;
        padding: 30px;
        border-radius: 16px;
        width: 550px;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
        animation: fadeSlideUp 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        max-height: 90vh;
        overflow-y: auto;
    }

        .modal-box h3 {
            margin-bottom: 24px;
            color: var(--navy-800, #0f1c3f);
            font-size: 20px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-box label {
            display: block;
            margin-bottom: 6px;
            font-size: 13px;
            color: var(--text-secondary, #64748b);
            font-weight: 700;
        }

            .modal-box label.required::after {
                content: " *";
                color: #ef4444;
            }

        .modal-box input, .modal-box select {
            width: 100%;
            padding: 12px 14px;
            border: 1.5px solid var(--border, #e2e8f0);
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 18px;
            outline: none;
            font-family: inherit;
            font-weight: 500;
            transition: border-color 0.2s;
        }

            .modal-box input:focus, .modal-box select:focus {
                border-color: var(--accent, #3b82f6);
            }

        .modal-box .form-row {
            display: flex;
            gap: 16px;
        }

            .modal-box .form-row > div {
                flex: 1;
            }

        .modal-box .modal-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 10px;
        }

    /* Deactivated Modal adjustments */
    .deactivated-modal {
        width: 420px;
        text-align: center;
        overflow: hidden;
        border-radius: 20px;
    }

    .deactivated-modal-header {
        background: #ef4444;
        padding: 25px 20px;
    }

    .deactivated-icon {
        width: 70px;
        height: 70px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 35px;
        color: white;
    }

    .deactivated-modal-header h3 {
        color: white;
        margin: 0;
        font-size: 20px;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .deactivated-modal-body {
        padding: 30px;
    }

        .deactivated-modal-body p {
            color: #334155;
            font-size: 15px;
            line-height: 1.5;
            margin-bottom: 15px;
            font-weight: 500;
        }

    .deactivated-reason {
        color: var(--text-secondary, #64748b);
        font-size: 13px;
        border-top: 1px solid var(--border, #e2e8f0);
        padding-top: 15px;
        margin-top: 10px;
    }

    .deactivated-btn-logout {
        width: 100%;
        padding: 14px;
        background: #ef4444;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: 20px;
        font-family: inherit;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .deactivated-btn-logout:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(239, 68, 68, 0.3);
        }
</style>

<div class="page-header">
    <div class="page-header-left">
        <h2 class="page-title">
            <i class="fas fa-users" style="color:var(--accent);"></i> Employee Management
        </h2>
        <p class="page-sub">Manage personnel, roles, and branch assignments.</p>
    </div>
</div>

<div class="res-layout-wrap">

    <div class="stats-grid-4">
        <div class="dash-style-card card-blue">
            <div class="stat-icon-wrapper icon-blue"><i class="fas fa-users"></i></div>
            <div class="stat-text">
                <h3 id="totalEmployees">@ViewBag.TotalEmployees</h3>
                <p>Total Employees</p>
            </div>
        </div>
        <div class="dash-style-card card-green">
            <div class="stat-icon-wrapper icon-green"><i class="fas fa-check-circle"></i></div>
            <div class="stat-text">
                <h3 id="activeEmployees">@ViewBag.ActiveEmployees</h3>
                <p>Active</p>
            </div>
        </div>
        <div class="dash-style-card card-orange">
            <div class="stat-icon-wrapper icon-orange"><i class="fas fa-id-card"></i></div>
            <div class="stat-text">
                <h3>@ViewBag.Drivers</h3>
                <p>Drivers</p>
            </div>
        </div>
        <div class="dash-style-card card-purple">
            <div class="stat-icon-wrapper icon-purple"><i class="fas fa-user-tie"></i></div>
            <div class="stat-text">
                <h3>@ViewBag.Conductors</h3>
                <p>Conductors</p>
            </div>
        </div>
    </div>

    <div class="filter-toolbar-card">
        <div class="search-group">
            <i class="fas fa-search"></i>
            <input type="text" id="searchEmployee" placeholder="Search employee..." onkeyup="filterEmployees()">
        </div>
        <select id="filterPosition" class="filter-select" onchange="filterEmployees()">
            <option value="">All Positions</option>
            <option value="Admin">Admin</option>
            <option value="HeadTeller">Head Teller</option>
            <option value="Teller">Teller</option>
            <option value="Dispatcher">Dispatcher</option>
            <option value="Driver">Driver</option>
            <option value="Conductor">Conductor</option>
            <option value="SecurityGuard">Security Guard</option>
            <option value="Inspector">Inspector</option>
            <option value="BusMechanic">Bus Mechanic</option>
            <option value="FrontOffice">Front Office</option>
        </select>

        <div style="margin-left:auto; display:flex; gap:10px; align-items: center;">
            <button class="btn-ghost-sys" onclick="clearFilters()">
                <i class="fas fa-sync-alt"></i> Reset
            </button>
            @if (isAdmin)
            {
                <button class="btn-primary-sys" onclick="openAddModal()">
                    <i class="fas fa-plus"></i> Add Employee
                </button>
            }
        </div>
    </div>

    <div class="sys-card-table">
        <div class="sys-card-header">
            <div style="display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-address-book" style="color: var(--accent); font-size: 16px;"></i>
                <h3 style="margin: 0; font-size: 15px; font-weight: 800; color: var(--navy-800);">Employees Log</h3>
            </div>
            <span id="logCountBadge" style="background: var(--navy-50); color: var(--accent); padding: 4px 12px; border-radius: 20px; font-size: 11.5px; font-weight: 700;">
                @(ViewBag.TotalEmployees ?? "0") employees
            </span>
        </div>

        <div class="table-wrapper">
            <table class="sys-table">
                <thead>
                    <tr>
                        <th>Employee ID</th>
                        <th>Full Name</th>
                        <th>Contact</th>
                        <th>Gender</th>
                        <th>Address</th>
                        <th>Position</th>
                        <th>Branch</th>
                        <th>Hire Date</th>
                        <th>Status</th>
                        @if (isAdmin) {
                            <th class="sticky-action-col" style="text-align:center;">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody id="employeeTableBody">
                    @if (ViewBag.Employees != null)
                    {
                        @foreach (var emp in (List<PUBReservationSystem.Models.Employee>)ViewBag.Employees)
                        {
                            <tr data-name="@emp.Full_Name.ToLower()" data-position="@emp.Job_Position" data-branch="@(emp.Branch ?? "")">
                                <td style="font-weight:700; color:var(--accent);">
                                    @{
                                        string empIdStr = emp.Employee_ID?.ToString() ?? "0";
                                        string cleanId = empIdStr.Replace("EMP-", "");
                                        int empNumber = 0;
                                        int.TryParse(cleanId, out empNumber);
                                    }
                                    EMP-@(empNumber.ToString("D5"))
                                </td>
                                <td style="font-weight:700; color:var(--navy-800);">@emp.Full_Name</td>
                                <td>@emp.Contact_Number</td>
                                <td>@emp.Gender</td>
                                <td>@(emp.Address ?? "-")</td>
                                <td>@emp.Job_Position</td>
                                <td>@(emp.Branch ?? "-")</td>
                                <td>@emp.Hire_Date.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge-sys @(emp.Is_Active ? "badge-green" : "badge-red")">
                                        @(emp.Is_Active ? "Active" : "Inactive")
                                    </span>
                                </td>

                                @if (isAdmin)
                                {
                                    <td class="sticky-action-col" style="text-align:center;">
                                    <button class="action-btn edit" onclick="editEmployee('@emp.Employee_ID')"><i class="fas fa-edit"></i></button>
                                    <button class="action-btn delete" onclick="deleteEmployee('@emp.Employee_ID', '@emp.Full_Name')"><i class="fas fa-trash"></i></button>
                                </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (ViewBag.Employees == null || ((List<PUBReservationSystem.Models.Employee>)ViewBag.Employees).Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-users"></i>
                <p>No employees registered yet.</p>
            </div>
        }
    </div>

</div>

<div class="modal-overlay" id="addEmployeeModal">
    <div class="modal-box">
        <h3><i class="fas fa-user-plus" style="color:var(--accent);"></i> Add New Employee</h3>
        <div class="form-row">
            <div>
                <label class="required">Full Name</label>
                <input type="text" id="fullName" placeholder="e.g., Juan Dela Cruz" maxlength="100">
            </div>
            <div>
                <label class="required">Contact Number</label>
                <input type="text" id="contactNumber" placeholder="e.g., 09123456789" maxlength="11">
            </div>
        </div>
        <div class="form-row">
            <div>
                <label class="required">Gender</label>
                <select id="gender">
                    <option value="">Select</option>
                    <option>Male</option>
                    <option>Female</option>
                </select>
            </div>
            <div>
                <label class="required">Birthday</label>
                <input type="date" id="birthday">
            </div>
        </div>
        <label>Address</label>
        <input type="text" id="address" placeholder="e.g., Manila">
        <div class="form-row">
            <div class="form-group-sys">
                <label class="form-label-sys">Branch <span style="color:var(--red)">*</span></label>

                <select id="branchId" name="Branch_ID" class="form-control-sys" required>
                    <option value="">Select Branch</option>

                    @if (ViewBag.Branches != null)
                    {
                        @foreach (var branch in (List<PUBReservationSystem.Models.Branch>)ViewBag.Branches)
                        {
                            <option value="@branch.Branch_ID">@branch.Branch_Name</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="required">Job Position</label>
                <select id="jobPosition">
                    <option value="">Select Position</option>
                    <option>Admin</option>
                    <option>HeadTeller</option>
                    <option>Teller</option>
                    <option>Dispatcher</option>
                    <option>Driver</option>
                    <option>Conductor</option>
                    <option>SecurityGuard</option>
                    <option>Inspector</option>
                    <option>BusMechanic</option>
                    <option>FrontOffice</option>
                </select>
            </div>
        </div>
        <div class="modal-actions">
            <button class="btn-ghost-sys" onclick="closeAddModal()">Cancel</button>
            <button class="btn-primary-sys" onclick="saveEmployee()"><i class="fas fa-save"></i> Save Employee</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="width: 400px; text-align: center;">
        <div style="width: 70px; height: 70px; background: #fef2f2; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 32px; color: #ef4444;">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h3 style="justify-content: center; margin-bottom: 8px;">Delete Employee</h3>
        <p style="color: var(--text-secondary); font-weight: 500; font-size: 14px;">Are you sure you want to delete <strong id="deleteEmployeeName" style="color:var(--navy-800);"></strong>?</p>
        <p style="font-size: 12px; color: #ef4444; font-weight: 700; margin-bottom: 20px;">This action cannot be undone.</p>
        <input type="hidden" id="deleteEmployeeId">
        <div class="modal-actions" style="justify-content: center;">
            <button class="btn-ghost-sys" onclick="closeDeleteModal()">Cancel</button>
            <button class="btn-primary-sys" style="background:#ef4444;" onclick="confirmDelete()">Delete</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deactivatedNotificationModal">
    <div class="modal-box deactivated-modal" style="padding:0;">
        <div class="deactivated-modal-header">
            <div class="deactivated-icon">
                <i class="fas fa-user-slash"></i>
            </div>
            <h3>ACCOUNT DEACTIVATED</h3>
        </div>
        <div class="deactivated-modal-body">
            <p id="deactivatedMessage">Your account has been deactivated by the administrator.</p>
            <p class="deactivated-reason">Please contact the system administrator for more information.</p>
            <button class="deactivated-btn-logout" onclick="logoutAfterDeactivation()">
                <i class="fas fa-sign-out-alt"></i> Logout Now
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ===================== FILTER & ANIMATION SYSTEM =====================
        function filterEmployees() {
            var search = (document.getElementById('searchEmployee').value || '').toLowerCase();
            var position = document.getElementById('filterPosition').value;

            // FIX: Safely check if filterBranch exists before reading its value
            var branchEl = document.getElementById('filterBranch');
            var branch = branchEl ? branchEl.value : '';

            var rows = document.querySelectorAll('#employeeTableBody tr');

            let visibleCount = 0;
            let activeCount = 0;

            rows.forEach(row => {
                var name = row.getAttribute('data-name') || '';
                var pos = row.getAttribute('data-position') || '';
                var br = row.getAttribute('data-branch') || '';
                var isActive = row.querySelector('.badge-green') !== null;

                var matchesSearch = name.includes(search);
                var matchesPosition = !position || pos === position;
                var matchesBranch = !branch || br === branch;

                var match = matchesSearch && matchesPosition && matchesBranch;

                if (match) {
                    if (row.classList.contains('hide-row')) {
                        row.classList.remove('hide-row');
                        void row.offsetWidth; // Force reflow

                        row.style.transition = 'opacity 0.3s ease, transform 0.3s ease, background 0.15s';
                        row.style.transitionDelay = (visibleCount * 0.03) + 's';
                        row.classList.remove('slide-standby');
                    }
                    visibleCount++;
                    if(isActive) activeCount++;
                } else {
                    row.style.transition = 'none';
                    row.style.transitionDelay = '0s';
                    row.classList.add('hide-row');
                    row.classList.add('slide-standby');
                }
            });

            // Update stats dynamically
            document.getElementById('totalEmployees').textContent = visibleCount;
            document.getElementById('activeEmployees').textContent = activeCount;

            var badge = document.getElementById('logCountBadge');
            if(badge) {
                badge.textContent = visibleCount + (visibleCount === 1 ? ' employee' : ' employees');
            }
        }

        // 🛑 FIXED: Cleaned up reset logic to prevent crashes
                function clearFilters() {
            // Clear input fields
            document.getElementById('searchEmployee').value = '';
            document.getElementById('filterPosition').value = '';

            // Safely reset branch filter if it exists
            var branchEl = document.getElementById('filterBranch');
            if (branchEl) {
                branchEl.value = '';
            }

            // Re-run filter to refresh and show all rows again
            filterEmployees();

            // ✅ Add the success toast notification
            if (typeof showToast === "function") {
                showToast("Filters reset successfully!", "success");
            }
        }

        // ===================== MODAL LOGIC =====================
        function openAddModal() {
            document.getElementById('addEmployeeModal').classList.add('active');
            document.getElementById('fullName').value = '';
            document.getElementById('contactNumber').value = '';
            document.getElementById('gender').value = '';
            document.getElementById('birthday').value = '';
            document.getElementById('address').value = '';
            document.getElementById('branchId').value = '';
            document.getElementById('jobPosition').value = '';
        }

                // ✅ NEW: Strict Contact Validation — Numbers only, max 11 digits
        document.getElementById('contactNumber').addEventListener('input', function (e) {
            // Strip anything that isn't a number
            let input = e.target.value.replace(/[^0-9]/g, '');
            e.target.value = input;
        });

        function closeAddModal() {
            document.getElementById('addEmployeeModal').classList.remove('active');
        }

        function saveEmployee() {
        var fullName = document.getElementById('fullName').value.trim();
        var contactNumber = document.getElementById('contactNumber').value.trim();
        var gender = document.getElementById('gender').value;
        var birthday = document.getElementById('birthday').value;
        var address = document.getElementById('address').value.trim();
        var branchId = document.getElementById('branchId').value;
        var jobPosition = document.getElementById('jobPosition').value;

        if (!fullName || !contactNumber || !gender || !birthday || !jobPosition || !branchId) {
            showToast('Please fill all required fields.', 'warning');
            return;
        }

        // ✅ NEW CRITICAL VALIDATION: Ensures exactly 11 digits are provided
        if (contactNumber.length !== 11) {
            showToast('Contact number must be exactly 11 digits (e.g., 09123456789).', 'warning');
            return;
        }

        var saveBtn = document.querySelector('#addEmployeeModal .btn-primary-sys');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

        fetch('/Home/SaveEmployee', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `fullName=${encodeURIComponent(fullName)}&contactNumber=${encodeURIComponent(contactNumber)}&gender=${encodeURIComponent(gender)}&address=${encodeURIComponent(address)}&jobPosition=${encodeURIComponent(jobPosition)}&branchId=${encodeURIComponent(branchId)}&birthday=${encodeURIComponent(birthday)}`
        })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    var branchName = document.getElementById('branchId').options[document.getElementById('branchId').selectedIndex].text;
                    insertEmployeeRow(data.empId, fullName, contactNumber, gender, address, jobPosition, branchName, birthday);
                    updateStatCards();

                    closeAddModal();
                    showToast(data.message, 'success');
                } else {
                    showToast(data.message, 'error');
                }
            })
            .finally(() => {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Employee';
            });
        }

        function insertEmployeeRow(id, name, contact, gender, address, position, branch, bday) {
            var tbody = document.getElementById('employeeTableBody');
            var newRow = document.createElement('tr');
            newRow.setAttribute('data-name', name.toLowerCase());
            newRow.setAttribute('data-position', position);
            newRow.setAttribute('data-branch', branch);

            var date = new Date(bday);
            var formattedDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

            newRow.innerHTML = `
                <td style="font-weight:700; color:var(--accent);">${id}</td>
                <td style="font-weight:700; color:var(--navy-800);">${name}</td>
                <td>${contact}</td>
                <td>${gender}</td>
                <td>${address || '-'}</td>
                <td>${position}</td>
                <td>${branch}</td>
                <td>${formattedDate}</td>
                <td><span class="badge-sys badge-green">Active</span></td>
                <td class="sticky-action-col" style="text-align:center;">
                    <button class="action-btn edit" onclick="editEmployee('${id}')"><i class="fas fa-edit"></i></button>
                    <button class="action-btn delete" onclick="deleteEmployee('${id}', '${name}')"><i class="fas fa-trash"></i></button>
                </td>
            `;

            tbody.prepend(newRow);
        }

        function updateStatCards() {
            var totalEl = document.getElementById('totalEmployees');
            var activeEl = document.getElementById('activeEmployees');
            var badgeEl = document.getElementById('logCountBadge');

            totalEl.textContent = parseInt(totalEl.textContent) + 1;
            activeEl.textContent = parseInt(activeEl.textContent) + 1;
            badgeEl.textContent = totalEl.textContent + ' employees';
        }

        document.getElementById('fullName').addEventListener('input', function (e) {
            let input = e.target.value.replace(/[^a-zA-Z\s]/g, '');
            input = input.toLowerCase().replace(/\b\w/g, function(char) {
                return char.toUpperCase();
            });
            e.target.value = input;
        });

        function editEmployee(employeeId) {
            alert('Edit Employee: ' + employeeId + ' - Implement edit functionality');
        }

        function deleteEmployee(employeeId, employeeName) {
            document.getElementById('deleteEmployeeId').value = employeeId;
            document.getElementById('deleteEmployeeName').textContent = employeeName;
            document.getElementById('deleteModal').classList.add('active');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('active');
        }

        function confirmDelete() {
            var employeeId = document.getElementById('deleteEmployeeId').value;

            fetch('/Home/DeleteEmployee', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'employeeId=' + encodeURIComponent(employeeId)
            })
            .then(response => response.json())
            .then(data => {
                closeDeleteModal();
                if (data.success) {
                    if (typeof showToast === "function") {
                        showToast(data.message, 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        location.reload();
                    }
                } else {
                    if (typeof showToast === "function") {
                        showToast(data.message, 'error');
                    } else {
                        alert(data.message);
                    }
                }
            })
            .catch(error => {
                alert('Error deleting employee: ' + error);
            });
        }

        // Close modals when clicking outside
        document.getElementById('addEmployeeModal').addEventListener('click', function(e) {
            if (e.target === this) closeAddModal();
        });

        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === this) closeDeleteModal();
        });
    </script>
}