            <div style="display:grid; grid-template-columns:1fr 1.2fr; gap:20px; padding:24px;">

                <div style="background:#f1f5f9; border-radius:12px; padding:16px; display:flex; flex-direction:column; gap:12px; border:1px solid #e2e8f0;">
                    <h5 style="margin:0; font-size:12px; font-weight:700; text-transform:uppercase; color:#475569; letter-spacing:0.5px;">Current Booking Anchor</h5>

                    <input type="hidden" id="modReservationId" />
                    <input type="hidden" id="modCurrentFare" />

                    <div>
                        <label style="font-size:11px; color:#64748b; display:block; margin-bottom:2px;">Passenger Name</label>
                        <strong id="lblPassenger" style="font-size:14px; color:#0f172a;">—</strong>
                    </div>
                    <div>
                        <label style="font-size:11px; color:#64748b; display:block; margin-bottom:2px;">Current Scheduled Route</label>
                        <span id="lblCurrentRoute" style="font-size:12.5px; font-weight:600; color:#1e293b; display:block;">—</span>
                        <small id="lblCurrentTripId" style="color:#2563eb; font-weight:700;"></small>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                        <div>
                            <label style="font-size:11px; color:#64748b; display:block; margin-bottom:2px;">Seat Assigned</label>
                            <strong id="lblCurrentSeat" style="font-size:13px; color:#0f172a;">—</strong>
                        </div>
                        <div>
                            <label style="font-size:11px; color:#64748b; display:block; margin-bottom:2px;">Total Fare Paid</label>
                            <strong id="lblCurrentFareDisplay" style="font-size:13px; color:#0fa66e;">₱0.00</strong>
                        </div>
                    </div>
                </div>

                <div style="display:flex; flex-direction:column; gap:14px;">
                    <h5 style="margin:0; font-size:12px; font-weight:700; text-transform:uppercase; color:#2563eb; letter-spacing:0.5px;">New Destination Properties</h5>

                    <div>
                        <label style="font-size:12px; font-weight:600; color:#334155; display:block; margin-bottom:6px;">Select Upgraded/Alternative Trip Schedule</label>
                        <select id="modTargetTripSelect" class="form-control" style="width:100%; height:40px; font-size:13px;" onchange="calculateFareDelta()">
                            <option value="">-- Choose New Available Schedule --</option>
                            @if (ViewBag.ActiveTripsAvailable != null)
                            {
                                @foreach (var trip in (List<PUBReservationSystem.Models.Trip>)ViewBag.ActiveTripsAvailable)
                                {
                                    <option value="@trip.Trip_ID" data-price="@trip.Base_Fare">
                                        #@trip.Trip_ID | @trip.Origin ➔ @trip.Destination (@trip.Scheduled_Departure_Time?.ToString("hh:mm tt")) - ₱@trip.Base_Fare.ToString("N2")
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div>
                        <label style="font-size:12px; font-weight:600; color:#334155; display:block; margin-bottom:6px;">New Target Seat Assignment</label>
                        <input type="text" id="modNewSeatInput" class="form-control" placeholder="Ex: 12A, 14" style="height:40px; font-size:13px; text-transform:uppercase;" />
                    </div>

                    <div style="background:#f8fafc; border:1px dashed #cbd5e1; border-radius:10px; padding:14px; margin-top:5px;">
                        <div style="display:flex; justify-content:space-between; font-size:12px; color:#475569; margin-bottom:6px;">
                            <span>New Target Line Cost:</span>
                            <span id="summaryNewFare">₱0.00</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; font-size:12px; color:#475569; margin-bottom:8px; padding-bottom:8px; border-bottom:1px solid #e2e8f0;">
                            <span>Credit from Prior Ticket:</span>
                            <span id="summaryCreditPaid">-₱0.00</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; font-size:13.5px; font-weight:700; color:#0f172a;">
                            <span style="color:#c2410c;"><i class="fas fa-wallet"></i> Additional Due:</span>
                            <span id="summaryDueAmount" style="color:#dc2626; font-size:15px;">₱0.00</span>
                        </div>
                    </div>
                </div>

            </div>

            <div style="padding:14px 24px; background:#f8fafc; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:8px;">
                <button type="button" class="btn-filter-sys" onclick="closeModal('editReservationModal')" style="height:38px;">Close Window</button>
                <button type="button" class="btn-primary-sys" onclick="submitTripModification()" style="height:38px; padding:0 20px; background:#2563eb; border-color:#2563eb;">
                    <i class="fas fa-receipt"></i> Authorize & Bill Exchange
                </button>
            </div>

        </div>
    </div>


<!-- SINGLE RESERVATION CANCELLATION MODAL -->
<div class="modal-overlay" id="singleCancelModal" style="z-index: 99999;">
    <div class="sys-modal" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4><i class="fas fa-exclamation-triangle" style="color:#ef4444;"></i> Confirm Void Request</h4>
            <button type="button" class="btn-close-modal" onclick="closeModal('singleCancelModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p>You are about to cancel and void reservation reference <strong id="singleCancelTargetDisplay" style="color:#dc2626; background:#fef2f2; padding:2px 6px; border-radius:4px; font-family:monospace;">—</strong>.</p>
            <p style="margin-top: 8px; color: #64748b; font-size: 13px;">This transaction will release the assigned seat immediately. This action cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-secondary" onclick="closeModal('singleCancelModal')">Discard</button>
            <button type="button" class="btn-primary-sys" id="btnConfirmSingleCancel" style="background:#ef4444; border-color:#ef4444;" onclick="executeSingleCancel()">Yes, Void Record</button>
        </div>
    </div>
</div>



    <!-- CANCEL ALL MODAL -->
    <div class="modal-overlay" id="cancelAllModal" style="z-index: 99999;">
        <div class="sys-modal" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h4><i class="fas fa-exclamation-triangle" style="color:#ef4444;"></i> Confirm Bulk Cancellation</h4>
                <button type="button" class="btn-close-modal" onclick="closeModal('cancelAllModal')">&times;</button>
            </div>
            <div class="modal-body">
                <p>You are about to cancel <strong><span id="cancelCountDisplay">0</span></strong> reservation(s). Do you want to proceed?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost-sys" onclick="closeModal('cancelAllModal')">Cancel</button>
                <button type="button" class="btn-primary-sys" style="background:#ef4444;" onclick="executeCancelAll()">Yes, Confirm Cancel</button>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            // ===================== GLOBALS =====================
            var selectedSeats    = [];
            var currentBaseFare  = 0;
            var currentTripId    = '';
            var currentTripLabel = '';
            var currentBusName   = "TBA";
            var currentBodyNo    = "TBA";
            var successPayloads  = [];
            var successResults   = [];
            var isMovingToNextStep = false;

            document.addEventListener('DOMContentLoaded', function() {


                updateStatCards();
                fetchRoutes();

                var routeSel = document.getElementById('routeSelect');
                if (routeSel) routeSel.addEventListener('change', loadTrips);

                var tripSel = document.getElementById('tripSelect');
                if (tripSel) {
                    tripSel.addEventListener('change', function() {
                        var opt = this.options[this.selectedIndex];
                        if (opt && this.value) {
                            currentBusName = opt.getAttribute('data-bus') || "TBA";
                            currentBodyNo = opt.getAttribute('data-body') || "TBA";
                            loadSeatMap();
                        } else {
                            var seatMap = document.getElementById('seatMapSection');
                            if (seatMap) seatMap.style.display = 'none';
                        }
                    });
                }
            });

            document.addEventListener('input', function (e) {
                if (e.target.classList.contains('pax-name')) {
                    var cleanString = e.target.value.replace(/[^a-zA-Z\s-]/g, '');
                    e.target.value = cleanString.replace(/\b\w/g, function(char) { return char.toUpperCase(); });
                }
                if (e.target.classList.contains('pax-contact')) {
                    var numbersOnly = e.target.value.replace(/\D/g, '');
                    if (numbersOnly.length > 11) numbersOnly = numbersOnly.substring(0, 11);
                    e.target.value = numbersOnly;
                }
            });

            // ===================== DYNAMIC STAT CARDS =====================
            function updateStatCards() {
                var rows = document.querySelectorAll('#reservationsTableBody tr');
                var countTotal = 0, countConfirmed = 0, countCancelled = 0;

                rows.forEach(function(row) {
                    if (row.classList.contains('empty-state') || row.cells.length < 5) return;
                    countTotal++;
                    var status = row.getAttribute('data-status');
                    if (status === 'Cancelled') countCancelled++;
                    else countConfirmed++;
                });

                animateNumber('stat-total', countTotal);
                animateNumber('stat-confirmed', countConfirmed);
                animateNumber('stat-cancelled', countCancelled);
            }

            function animateNumber(elementId, endValue) {
                var el = document.getElementById(elementId);
                if (!el) return;
                var startValue = parseInt(el.textContent.replace(/,/g, '')) || 0;
                if (startValue === endValue) return;

                var duration = 800, startTimestamp = null;
                var step = function(timestamp) {
                    if (!startTimestamp) startTimestamp = timestamp;
                    var progress = Math.min((timestamp - startTimestamp) / duration, 1);
                    var easeProgress = 1 - Math.pow(1 - progress, 3);
                    var current = Math.floor(easeProgress * (endValue - startValue) + startValue);
                    el.textContent = current.toLocaleString();
                    if (progress < 1) window.requestAnimationFrame(step);
                    else el.textContent = endValue.toLocaleString();
                };
                window.requestAnimationFrame(step);
            }

            // ===================== MODAL HELPERS =====================
            function openModal(modalId) {
                var modal = document.getElementById(modalId);
                if (modal) {
                    modal.style.display = ''; // Clear inline block
                    modal.classList.remove('hide');
                    modal.classList.add('show');
                }
            }

                function closeModal(modalId) {
            var modal = document.getElementById(modalId);
            if (modal) {
                modal.classList.remove('show');
                modal.classList.add('hide'); // Injects the custom smooth fade out rules

                // Wait exactly 200ms for the slide-down/fade animation to finish before removing from layout flow
                setTimeout(function() {
                    modal.style.display = "none";
                    modal.classList.remove('hide');

                    if (modalId === 'createResModal' && !isMovingToNextStep) resetWizard();
                    if (modalId === 'passengerModal') isMovingToNextStep = false;
                    if (modalId === 'successModal') resetWizard();
                }, 200);
            }
        }

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    var open = document.querySelectorAll('.modal-overlay.show');
                    if (open.length) closeModal(open[open.length - 1].id);
                }
            });

            // ===================== STEP 1 — ROUTE & SEAT =====================
            function resetWizard() {
                selectedSeats = []; currentBaseFare = 0; currentTripId = ''; currentTripLabel = '';
                var routeSel = document.getElementById('routeSelect');
                if (routeSel) routeSel.selectedIndex = 0;

                var tripSel = document.getElementById('tripSelect');
                if (tripSel) {
                    tripSel.innerHTML = '<option value="">Select Route First...</option>';
                    tripSel.disabled = true;
                }

                var mapSec = document.getElementById('seatMapSection');
                if (mapSec) mapSec.style.display = 'none';

                var btn = document.getElementById('btnProceed');
                if (btn) btn.disabled = true;

                updateSeatCount();
            }

            function fetchRoutes() {
                fetch('/Home/GetAllRoutes')
                .then(r => r.json())
                .then(routes => {
                    var sel = document.getElementById('routeSelect');
                    if(!sel) return;
                    sel.innerHTML = '<option value="">Select Origin → Destination...</option>';
                    routes.forEach(r => {
                        sel.innerHTML += `<option value="${r.origin}|${r.destination}">${r.route}</option>`;
                    });
                })
                .catch(err => console.error("Route fetch failed:", err));
            }

            function loadTrips() {
                var val = document.getElementById('routeSelect').value;
                var ts = document.getElementById('tripSelect');
                var mapSec = document.getElementById('seatMapSection');

                if (mapSec) mapSec.style.display = 'none';

                if (!val) {
                    ts.innerHTML = '<option value="">Select Route First...</option>';
                    ts.disabled = true;
                    return;
                }

                var parts = val.split('|');
                ts.innerHTML = '<option value="">Loading...</option>';

                fetch('/Home/GetTripsByRoute?origin=' + encodeURIComponent(parts[0]) + '&destination=' + encodeURIComponent(parts[1]))
                .then(r => r.json())
                .then(trips => {
                    ts.innerHTML = '<option value="">Select a Trip...</option>';
                    if (!trips || trips.length === 0) {
                        ts.innerHTML = '<option value="">No trips available.</option>';
                        return;
                    }
                    trips.forEach(t => {
                        var opt = document.createElement('option');
                        opt.value = t.tripId;
                        opt.setAttribute('data-fare', t.baseFare);
                        opt.setAttribute('data-bus', t.busName);
                        opt.setAttribute('data-label', t.busName + ' — ' + t.departure);
                        opt.setAttribute('data-body', t.bodyNo || 'TBA');
                        opt.textContent = t.busName + ' — ' + t.departure;
                        ts.appendChild(opt);
                    });
                    ts.disabled = false;
                })
                .catch(err => {
                    ts.innerHTML = '<option value="">Error loading trips.</option>';
                });
            }

            function loadSeatMap() {
                var ts = document.getElementById('tripSelect');
                var mapSec = document.getElementById('seatMapSection');
                currentTripId = ts.value;

                if (!currentTripId) {
                    if(mapSec) mapSec.style.display = 'none';
                    return;
                }

                var opt = ts.options[ts.selectedIndex];
                currentBaseFare  = parseFloat(opt.getAttribute('data-fare')) || 0;
                currentTripLabel = opt.getAttribute('data-label') || '';

                fetch('/Home/GetAvailableSeats?tripId=' + encodeURIComponent(currentTripId))
                    .then(r => r.json())
                    .then(seats => {
                        if(mapSec) mapSec.style.display = 'block';
                        buildGrid(seats);
                    })
                    .catch(err => console.error("Error loading seats:", err));
            }

            function buildGrid(seatsData) {
                var grid = document.getElementById('seatGrid');
                if(!grid) return;
                grid.innerHTML = '';
                selectedSeats = [];
                updateSeatCount();
                var seatNum = 1;

                for (var row = 0; row < 10; row++) {
                    for (var col = 0; col < 5; col++) {
                        if (col === 2) {
                            grid.innerHTML += '<div class="seat aisle"></div>';
                            continue;
                        }
                        var info    = seatsData.find(s => s.seatNumber === seatNum);
                        var booked  = info ? info.isBooked : false;
                        var cls     = booked ? 'booked' : 'available';
                        var onclick = booked ? '' : `onclick="toggleSeat(${seatNum})"`;

                        grid.innerHTML += `<div class="seat ${cls}" id="seat-${seatNum}" ${onclick}>${seatNum}</div>`;
                        seatNum++;
                    }
                }
            }

        // 1. Prepare and Open Modal
            function openCancelAllModal() {
                const visibleRows = document.querySelectorAll("#reservationsTableBody tr:not([style*='display: none'])");
                const ids = [];

                visibleRows.forEach(row => {
                    const id = row.getAttribute("data-res-id");
                    // Only grab rows that aren't ALREADY cancelled
                    const status = row.getAttribute("data-status");
                    if (id && status !== "Cancelled") ids.push(id);
                });

                // ✅ FIXED: Replaced the default browser alert pop-up with a premium system toast
                if (ids.length === 0) {
                    showToast("No active visible reservations to cancel.", "warning");
                    return;
                }

                const span = document.getElementById("cancelCountDisplay");
                if (span) span.innerText = ids.length;

                openModal('cancelAllModal');
            }

                    function executeCancelAll() {
                        const visibleRows = document.querySelectorAll("#reservationsTableBody tr:not([style*='display: none'])");
                        const ids = [];
                        const rowsToUpdate = []; // Keep track of the rows we are altering

                        visibleRows.forEach(row => {
                            const id = row.getAttribute("data-res-id");
                            const status = row.getAttribute("data-status");
                            if (id && status !== "Cancelled") {
                                ids.push(id);
                                rowsToUpdate.push(row);
                            }
                        });

                        const btn = document.querySelector("#cancelAllModal .btn-primary-sys");
                        btn.disabled = true;
                        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Cancelling...';

                        fetch('/Home/CancelAllReservations', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(ids)
                        })
                                .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            closeModal('cancelAllModal');

                            // --- THE MULTI-LINE FORMATTED TOAST ---
                            let customMessage = `
                                <span style="display: flex; flex-direction: column; gap: 4px; line-height: 1.3; margin-left: 4px;">
                                    <strong style="color: #10b981; font-size: 14px;">${data.jobPosition}: ${data.adminName}</strong>
                                    <span style="color: #94a3b8; font-size: 11.5px; font-family: monospace;">User ID: ${data.adminId}</span>
                                    <span style="color: #ffffff; font-size: 12.5px; margin-top: 2px;">Cancelled all the Reservations.</span>
                                </span>
                            `;

                            if (typeof showToast === "function") {
                                showToast(customMessage);
                            }
                            // --------------------------------------

                            rowsToUpdate.forEach(row => {
                                row.setAttribute('data-status', 'Cancelled');

                                let pill = row.querySelector('.res-status-pill');
                                if (pill) {
                                    pill.className = 'res-status-pill status-cancelled';
                                    pill.textContent = 'Cancelled';
                                }

                                let actionCol = row.querySelector('.sticky-action-col');
                                if (actionCol) actionCol.innerHTML = '<span style="color:var(--text-muted); font-size:12px;">Closed</span>';

                                row.style.transition = 'background 0.4s';
                                row.style.background = '#fff1f2';
                                setTimeout(() => { row.style.background = ''; }, 1500);
                            });

                            updateStatCards();
                            filterReservations();

                            btn.disabled = false;
                            btn.innerHTML = 'Yes, Confirm Cancel';
                        } else {
                            alert("Error: " + data.message);
                            btn.disabled = false;
                            btn.innerHTML = 'Yes, Confirm Cancel';
                        }
                    })
                        .catch(err => {
                            console.error(err);
                            alert("A system error occurred.");
                            btn.disabled = false;
                            btn.innerHTML = 'Yes, Confirm Cancel';
                        });
                    }

            function toggleSeat(n) {
                var el = document.getElementById('seat-' + n);
                var idx = selectedSeats.indexOf(n);
                if (idx >= 0) {
                    selectedSeats.splice(idx, 1);
                    el.classList.remove('selected');
                    el.classList.add('available');
                } else {
                    selectedSeats.push(n);
                    el.classList.remove('available');
                    el.classList.add('selected');
                }
                updateSeatCount();
                var btnProceed = document.getElementById('btnProceed');
                if(btnProceed) btnProceed.disabled = selectedSeats.length === 0;
            }

            function updateSeatCount() {
                var el = document.getElementById('selectedSeatCount');
                if (el) el.textContent = selectedSeats.length;
            }

            function goToPaymentStep() {
                var tripSelect = document.getElementById('tripSelect');
                if (!tripSelect || !tripSelect.value) {
                    if (typeof showToast === "function") showToast('Please select a trip first.', 'warning');
                    else alert('Please select a trip first.');
                    return;
                }
                if (selectedSeats.length === 0) {
                    if (typeof showToast === "function") showToast('Please select at least one seat.', 'warning');
                    else alert('Please select at least one seat.');
                    return;
                }
                proceedToPassengers();
            }

            // ===================== STEP 2 — PASSENGER DETAILS =====================
            function proceedToPassengers() {
                isMovingToNextStep = true;
                closeModal('createResModal');
                var container = document.getElementById('passengerFormsContainer');
                if(!container) return;
                container.innerHTML = '';
                selectedSeats.sort(function (a, b) { return a - b; });

                selectedSeats.forEach(function (seat) {
                    container.innerHTML +=
                        '<div class="passenger-card" id="card-seat-' + seat + '">' +
                            '<div class="passenger-card-header"><i class="fas fa-couch" style="color:#3b6cf7;"></i> Seat #' + seat + '</div>' +
                            '<div class="passenger-grid">' +
                                '<div class="form-group"><label>Full Name</label>' +
                                    '<input type="text" class="form-control pax-name" placeholder="Juan Dela Cruz"></div>' +
                                '<div class="form-group"><label>Contact</label>' +
                                    '<input type="text" class="form-control pax-contact" placeholder="09XXXXXXXXX"></div>' +
                                '<div class="form-group"><label>Type</label>' +
                                    '<select class="form-control pax-type" onchange="recalcTotal()">' +
                                        '<option value="Regular">Regular</option>' +
                                        '<option value="Student">Student (-20%)</option>' +
                                        '<option value="PWD">PWD (-20%)</option>' +
                                        '<option value="Senior">Senior (-20%)</option>' +
                                    '</select></div>' +
                            '</div>' +
                        '</div>';
                });

                recalcTotal();
                openModal('passengerModal');
            }

            function backToSeats() {
                closeModal('passengerModal');
                openModal('createResModal');
            }

            function recalcTotal() {
                var fareLines = document.getElementById('fareLines');
                if(!fareLines) return;
                fareLines.innerHTML = '';
                var total = 0;
                var types = document.querySelectorAll('.pax-type');

                fareLines.innerHTML += '<div class="fare-line"><span>Base Fare per Seat</span><span>₱' + currentBaseFare.toLocaleString('en-US', {minimumFractionDigits:2}) + '</span></div>';

                types.forEach(function (sel, i) {
                    var seat = selectedSeats[i];
                    var isDisc = sel.value !== 'Regular';
                    var fare   = isDisc ? currentBaseFare * 0.8 : currentBaseFare;
                    var disc   = isDisc ? ' <span style="color:var(--orange,#f07d1c); font-size:11px;">−20%</span>' : '';
                    fareLines.innerHTML += '<div class="fare-line"><span>Seat #' + seat + ' · ' + sel.value + disc + '</span><span>₱' + fare.toLocaleString('en-US', {minimumFractionDigits:2}) + '</span></div>';
                    total += fare;
                });

                var totalDisplay = document.getElementById('totalFareDisplay');
                var seatLabel = document.getElementById('totalSeatsLabel');

                if(totalDisplay) totalDisplay.textContent = '₱' + total.toLocaleString('en-US', {minimumFractionDigits:2});
                if(seatLabel) seatLabel.textContent  = '(' + selectedSeats.length + ' seat' + (selectedSeats.length !== 1 ? 's' : '') + ')';
            }

            // ===================== STEP 3 — SUBMIT =====================
                    async function submitReservations() {
                const btn = document.getElementById('btnConfirmPay');
                const cards = document.querySelectorAll('.passenger-card');
                const payloads = [];
                let errorMsg = '';

                // 1. Client-Side Validation
                for (let i = 0; i < cards.length; i++) {
                    const card = cards[i];
                    const name = card.querySelector('.pax-name').value.trim();
                    const contact = card.querySelector('.pax-contact').value.trim();
                    const type = card.querySelector('.pax-type').value;

                    if (!name) { errorMsg = 'Please provide a full name for all passengers.'; break; }
                    if (contact && contact.length !== 11) { errorMsg = 'Contact numbers must be 11 digits.'; break; }

                    payloads.push({
                        passengerName: name,
                        contactNumber: contact,
                        passengerType: type,
                        tripId: currentTripId,
                        seatNumber: String(selectedSeats[i]),
                        paymentMethod: document.getElementById('paymentMethod').value
                    });
                }

                if (errorMsg) {
                    if (typeof showToast === "function") showToast(errorMsg, 'warning');
                    else alert(errorMsg);
                    return;
                }

                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

                const results = [];

                // 2. Sequential Processing
                for (const p of payloads) {
                    const formData = new URLSearchParams();
                    Object.keys(p).forEach(key => formData.append(key, p[key]));

                    try {
                        const response = await fetch('/Home/SaveReservation', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: formData.toString()
                        });

                        if (!response.ok) throw new Error('Network error');
                        const res = await response.json();
                        results.push(res);
                    } catch (err) {
                        console.error("Save Error:", err);
                        results.push({ success: false, message: err.message });
                    }
                }

                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check-circle"></i> Confirm & Pay';

                // 3. UI Updates
                closeModal('passengerModal');

                // Only proceed to success modal if at least one reservation was successful
                const successCount = results.filter(r => r.success).length;
                if (successCount > 0) {
                    window.successResults = results;
                    showSuccessModal(payloads, results);
                    insertRowsIntoTable(payloads, results); // This function now handles the "Created At" column
                }

