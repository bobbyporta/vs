                    var resId = d.reservation_ID || '—';
                    var fare = d.total_Amount;

                    var travelDate = d.reservation_Date || '—';
                    var createdAt = d.created_At || '—';

                    var busName = (d.trip && d.trip.bus) ? d.trip.bus.bus_Name : "Unknown";
                    var bodyNo = (d.trip && d.trip.bus) ? d.trip.bus.body_No : "Unknown";

                    // FIX 1: Build the Exact Route string from the Server Data!
                    var exactRoute = (d.trip && d.trip.origin && d.trip.destination)
                        ? d.trip.origin + ' &rarr; ' + d.trip.destination
                        : 'N/A';

                    // FIX 2: Format the Departure Time properly instead of hardcoding a dash!
                    var depTime = '—';
                    if (d.trip && d.trip.departure_Time) {
                        depTime = new Date(d.trip.departure_Time).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }).toLowerCase();
                    }

                    var tr = document.createElement('tr');
                    tr.setAttribute('data-status', 'Confirmed');
                    tr.setAttribute('data-res-id', resId);
                    tr.setAttribute('data-passenger', d.passenger_Name);
                    tr.setAttribute('data-seat', d.seat_Number);
                    tr.setAttribute('data-amount', fare.toFixed(2));
                    tr.setAttribute('data-teller', currentTellerId);
                    tr.className = 'new-row-flash';

                    tr.innerHTML =
                        '<td style="text-align:center;"><input type="checkbox" class="reservation-checkbox" ' +
                        'data-id="' + resId + '" data-name="' + escHtml(d.passenger_Name) + '" ' +
                        'data-teller="' + currentTellerId + '" ' +
                        'data-seat="' + d.seat_Number + '" data-route="' + exactRoute + '" ' +
                        'data-date="' + travelDate + '" data-dep="' + depTime + '" ' +
                        'data-amount="' + fare.toFixed(2) + '" data-type="' + p.passengerType + '" ' +
                        'data-trip="' + currentTripId + '" data-bus="' + escHtml(busName) + '" data-body="' + escHtml(bodyNo) + '"></td>' +
                        '<td class="ref-id-text">' + resId + '</td>' +
                        '<td style="font-weight:600; color:var(--navy-800,#0f1c3f);">' + currentTripId + '</td>' +
                        '<td style="font-weight:600;">' + escHtml(busName) + '</td>' +
                        '<td style="color:var(--text-secondary);">' + escHtml(bodyNo) + '</td>' +
                        '<td style="font-weight:500;">' + escHtml(d.passenger_Name) + '</td>' +
                        '<td style="color:var(--text-secondary);">' + (p.contactNumber || '—') + '</td>' +
                        '<td style="color:var(--text-secondary);">' + exactRoute + '</td>' +  // Now correctly shows Manila -> Cebu
                        '<td style="color:var(--text-secondary); font-size:11px;">' + createdAt + '</td>' +
                        '<td style="color:var(--text-secondary);">' + travelDate + '</td>' +
                        '<td style="font-weight:500; font-size:12px;">' + depTime + '</td>' + // Now correctly shows 08:00 pm
                        '<td style="font-weight:700; color:var(--navy-800,#0f1c3f);">' + d.seat_Number + '</td>' +
                        '<td><span style="font-size:11px; font-weight:600; color:var(--text-secondary);">' + p.passengerType + '</span></td>' +
                        '<td style="font-weight:600; color:var(--green,#0fa66e);">₱' + fare.toLocaleString('en-US', { minimumFractionDigits: 2 }) + '</td>' +
                        '<td style="color:var(--text-secondary); font-size:12px;">' + currentTellerName + '</td>' +
                        '<td style="text-align:center;"><span class="res-status-pill status-confirmed">Confirmed</span></td>' +
                        '<td class="sticky-action-col" style="text-align:center;">' +
                        '<button class="btn-danger-sys" style="padding:5px 12px; font-size:11.5px;" onclick="cancelReservation(\'' + resId + '\', this)">' +
                        '<i class="fas fa-ban"></i> Cancel</button></td>';

                    tbody.insertBefore(tr, tbody.firstChild);
                });

                var badge = document.getElementById('resCountBadge');
                if (badge) {
                    var count = tbody.querySelectorAll('tr').length;
                    badge.textContent = count + ' booking' + (count !== 1 ? 's' : '');
