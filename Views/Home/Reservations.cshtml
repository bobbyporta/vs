                   // ===================== REAL-TIME POLLING (DOM DIFFING) =====================
            async function pollAndInjectReservations() {
                const role = '@ViewBag.Role';
                if (role !== "Admin" && role !== "HeadTeller") return;

                try {
                    const response = await fetch('/Home/GetLatestReservations');
                    if (!response.ok) throw new Error('Fetch failed');
                    const data = await response.json();

                    const tbody = document.getElementById('reservationsTableBody');
                    if (!tbody) return;

                    let needsStatUpdate = false;

                    // Process items in reverse (newest first)
                    data.reverse().forEach(item => {
                        const existingRow = document.querySelector(`tr[data-res-id="${item.resId}"]`);

                        if (!existingRow) {
                            // 1. New Reservation
                            needsStatUpdate = true;
                            const tr = document.createElement('tr');
                            tr.setAttribute('data-status', item.status);
                            tr.setAttribute('data-res-id', item.resId);
                            tr.className = 'new-row-flash';
                            tr.innerHTML = generateRowHTML(item);
                            tbody.insertBefore(tr, tbody.firstChild);
                        }
                        else {
                            // 2. Existing Reservation - Check Status
                            if (existingRow.getAttribute('data-status') !== item.status) {
                                needsStatUpdate = true;
                                existingRow.setAttribute('data-status', item.status);

                                // Update pill
                                const pill = existingRow.querySelector('.res-status-pill');
                                if (pill) {
                                    pill.className = `res-status-pill status-${item.status.toLowerCase()}`;
                                    pill.textContent = item.status;
                                }

                                // Handle Cancellation Logic
                                if (item.status === 'Cancelled') {
                                    const actionCol = existingRow.querySelector('.sticky-action-col');
                                    if (actionCol) actionCol.innerHTML = '<span style="color:var(--text-muted); font-size:12px;">Closed</span>';

                                    existingRow.style.transition = 'background 0.4s';
                                    existingRow.style.background = '#fff1f2';
                                    setTimeout(() => { existingRow.style.background = ''; }, 1500);

                                    // Trigger Seat Map update if active
                                    if (typeof currentTripId !== 'undefined' && currentTripId === item.tripId && typeof loadSeatMap === 'function') {
                                        loadSeatMap();
                                    }
                                }
                            }
                        }
                    });

                    // Trigger updates if changes occurred
                    if (needsStatUpdate) {
                        const count = tbody.querySelectorAll('tr:not(.empty-state)').length;
                        const badge = document.getElementById('resCountBadge');
                        if (badge) badge.innerText = `${count} bookings`;

                        if (typeof updateStatCards === 'function') updateStatCards();
                        if (typeof filterReservations === 'function') filterReservations();
                    }
                } catch (err) {
                    console.error("Polling error:", err);
                }
            }

            // Helper to generate row HTML structure
            function generateRowHTML(item) {
                return `
                    <td style="text-align:center;"><input type="checkbox" class="reservation-checkbox" data-id="${item.resId}"></td>
                    <td class="ref-id-text">${item.resId}</td>
                    <td style="font-weight:600; color:var(--navy-800);">#${item.tripId}</td>
                    <td style="font-weight:600;">${item.busName}</td>
                    <td style="color:var(--text-secondary);">${item.bodyNo}</td>
                    <td style="font-weight:500;">${item.passengerName}</td>
                    <td style="color:var(--text-secondary);">${item.contact || '—'}</td>
                    <td style="color:var(--text-secondary);">${item.route}</td>
                    <td style="color:var(--text-secondary); font-size:11px;">${item.createdAt}</td>
                    <td style="color:var(--text-secondary);">${item.travelDate}</td>
                    <td style="font-weight:500; font-size:12px;">${item.depTime}</td>
                    <td style="font-weight:700; color:var(--navy-800);">${item.seat}</td>
                    <td><span style="font-size:11px; font-weight:600; color:var(--text-secondary);">${item.type}</span></td>
                    <td style="font-weight:600; color:var(--green);">₱${item.fare.toLocaleString('en-US', { minimumFractionDigits: 2 })}</td>
                    <td style="color:var(--text-secondary); font-size:12px;">${item.tellerName}</td>
                    <td style="text-align:center;"><span class="res-status-pill status-${item.status.toLowerCase()}">${item.status}</span></td>
                    <td class="sticky-action-col" style="text-align:center;">
                        ${item.status === 'Cancelled'
                            ? '<span style="color:var(--text-muted); font-size:12px;">Closed</span>'
                            : `<button class="btn-danger-sys" style="padding:5px 12px; font-size:11.5px;" onclick="cancelReservation('${item.resId}', this)"><i class="fas fa-ban"></i> Cancel</button>`}
                    </td>`;
            }

            // Run polling
            setInterval(pollAndInjectReservations, 2000);






                    // Open and Populate the Modification Desk
            function openEditReservationModal(buttonEl) {
                // 1. Parse dataset variables from chosen row action button directly
                document.getElementById("modReservationId").value = buttonEl.getAttribute("data-id");
                document.getElementById("modCurrentFare").value = buttonEl.getAttribute("data-current-fare");

                document.getElementById("lblPassenger").textContent = buttonEl.getAttribute("data-passenger");
                document.getElementById("lblCurrentRoute").textContent = buttonEl.getAttribute("data-current-route");
                document.getElementById("lblCurrentTripId").textContent = buttonEl.getAttribute("data-current-current-trip");
                document.getElementById("lblCurrentSeat").textContent = buttonEl.getAttribute("data-current-seat");

                const baseFare = parseFloat(buttonEl.getAttribute("data-current-fare")) || 0;
                document.getElementById("lblCurrentFareDisplay").textContent = "₱" + baseFare.toLocaleString('en-US', {minimumFractionDigits: 2});

                // 2. Clear inputs in workspace configuration target rows
                document.getElementById("modTargetTripSelect").value = "";
                document.getElementById("modNewSeatInput").value = "";

                // Reset pricing parameters cleanly
                document.getElementById("summaryNewFare").textContent = "₱0.00";
                document.getElementById("summaryCreditPaid").textContent = "-₱" + baseFare.toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById("summaryDueAmount").textContent = "₱0.00";

                // 3. Render container window overlay block visible via flex mapping rules
                const modal = document.getElementById("editReservationModal");
                if(modal) modal.style.display = "flex";
            }

            // Compute the Financial Fare Delta Formula on drop-down changes
            function calculateFareDelta() {
                const selectEl = document.getElementById("modTargetTripSelect");
                const chosenOption = selectEl.options[selectEl.selectedIndex];

                const currentPaidAmount = parseFloat(document.getElementById("modCurrentFare").value) || 0;
                let targetNewTripFare = 0;

                if (selectEl.value && chosenOption) {
                    targetNewTripFare = parseFloat(chosenOption.getAttribute("data-price")) || 0;
                }

                // Calculation: New Price minus original credit baseline
                let financialDelta = targetNewTripFare - currentPaidAmount;
                if (financialDelta < 0) financialDelta = 0; // Guard rule against issuing systematic negative refunds

                // Render parameters into structural calculation summary layout
                document.getElementById("summaryNewFare").textContent = "₱" + targetNewTripFare.toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById("summaryDueAmount").textContent = "₱" + financialDelta.toLocaleString('en-US', {minimumFractionDigits: 2});
            }

            // Post transactional model update package directly onto our controller action endpoint map
            async function submitTripModification() {
                const resId = document.getElementById("modReservationId").value;
                const targetTripId = document.getElementById("modTargetTripSelect").value;
                const newSeatAssigned = document.getElementById("modNewSeatInput").value.trim().toUpperCase();

                // Structural client validations entry gate
                if(!targetTripId) {
                    showToast("Please choose an upgraded target travel trip schedule.", "warning");
                    return;
                }
                if(!newSeatAssigned) {
                    showToast("Please input a seat coordinate identifier allocation.", "warning");
                    return;
                }

                const payloadBundle = {
                    ReservationId: parseInt(resId),
                    NewTripId: parseInt(targetTripId),
                    NewSeatNumber: newSeatAssigned
                };

                try {
                    const response = await fetch('/Home/ProcessReservationModification', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ""
                        },
                        body: JSON.stringify(payloadBundle)
                    });

                    const callbackData = await response.json();

                    if (callbackData.success) {
                        showToast(callbackData.message || "Reservation ticket re-routed cleanly!", "success");
                        closeModal('editReservationModal');

                        // Re-trigger view table load metrics after brief window interval delays
                        setTimeout(() => { location.reload(); }, 1200);
                    } else {
                        showToast(callbackData.message || "Modification parameters validation failed.", "error");
                    }
                } catch(err) {
                    console.error("Pipeline failure routing:", err);
                    showToast("Database mapping engine error during transaction swap.", "error");
                }
            }

           



        </script>
    }