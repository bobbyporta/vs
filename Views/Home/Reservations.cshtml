/* Define the explicit fading closing state targeted by the JavaScript engine */
.modal-overlay.hide {
    opacity: 0 !important;
    visibility: hidden !important;
    transition: opacity 0.2s cubic-bezier(0.4, 0, 1, 1), visibility 0.2s !important;
}

/* Make the white modal container slide downwards slightly as it fades out */
.modal-overlay.hide .sys-modal {
    transform: translateY(15px) !important;
    transition: transform 0.2s cubic-bezier(0.4, 0, 1, 1) !important;
}

/* Fix the unstyled cancel button appearance seen in image_31c305.jpg */
.btn-secondary {
    height: 38px;
    padding: 0 18px;
    font-size: 12.5px;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid #cbd5e1;
    background: #ffffff;
