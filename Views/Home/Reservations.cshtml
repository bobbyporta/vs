            function escHtml(str) {
                return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

            // ===================== CANCEL =====================
                    // Global memory anchors to securely cache context between modal interaction layers
        var activeCancelResId = null;
        var activeCancelBtnRef = null;

        // Called immediately when a teller clicks the row action cancel icon
        function cancelReservation(resId, btn) {
            // Stash the specific values in memory coordinates
            window.activeCancelResId = resId;
            window.activeCancelBtnRef = btn;

            // Inject reference ID into the prompt dynamically
            const targetSpan = document.getElementById("singleCancelTargetDisplay");
            if (targetSpan) {
                targetSpan.innerText = resId;
            }

            // Call your system's smooth fade-in modal pipeline
            openModal('singleCancelModal');
        }

        // Authorized final step triggered by clicking the modal's primary button action
        async function executeSingleCancel() {
            const resId = window.activeCancelResId;
            const btn = window.activeCancelBtnRef;

            if (!resId || !btn) return;

            const modalBtn = document.getElementById('btnConfirmSingleCancel');
            modalBtn.disabled = true;
            modalBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Voiding...';

            try {
                const response = await fetch('/Home/CancelReservation', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reservationId: resId })
                });

                const data = await response.json();

                if (data.success) {
                    if (typeof showToast === "function") showToast(data.message, 'success');

                    var row = btn.closest('tr');
                    if (row) {
                        var pill = row.querySelector('.res-status-pill');
                        if (pill) {
                            pill.className = 'res-status-pill status-cancelled';
                            pill.textContent = 'Cancelled';
                        }
                        var td = btn.closest('td');
                        if (td) td.innerHTML = '<span style="color:var(--text-muted); font-size:12px;">Closed</span>';

                        row.setAttribute('data-status', 'Cancelled');
                        row.style.transition = 'background 0.4s';
                        row.style.background = '#fff1f2';
                        setTimeout(function () { row.style.background = ''; }, 1500);

                        // Instantly free up space maps if the teller has that specific trip workspace open
                        var rowTripId = row.getAttribute('data-trip');
                        if (typeof currentTripId !== 'undefined' && currentTripId === rowTripId) {
                            loadSeatMap();
                        }
                    }

                    updateStatCards();
                    closeModal('singleCancelModal');
                } else {
                    if (typeof showToast === "function") showToast(data.message, 'error');
                }
            } catch (err) {
                console.error("Cancellation network pipeline failure:", err);
                if (typeof showToast === "function") showToast("A transaction error stopped the cancel query request.", 'error');
            } finally {
                // Clean up configuration states after modal animation cycle ends
                modalBtn.disabled = false;
                modalBtn.innerHTML = 'Yes, Void Record';
            }
        }

            // ===================== FILTER =====================
                    function filterReservations() {
            // 1. Get current values from all filters
            const searchTerm = document.getElementById("searchPassenger").value.toLowerCase();
            const statusFilter = document.getElementById("filterStatus").value;
            const tellerFilter = document.getElementById("filterTeller") ? document.getElementById("filterTeller").value : "";

            const tbody = document.getElementById("reservationsTableBody");
            const rows = tbody.querySelectorAll("tr:not(.sys-table-empty-row)"); // Avoid evaluating an old empty indicator row

            let visibleCount = 0;
            let delayIndex = 0;

            // 2. Remove any existing empty-state indicator rows first to refresh the calculation layer
            const oldEmptyRow = tbody.querySelector(".sys-table-empty-row");
            if (oldEmptyRow) {
                oldEmptyRow.remove();
            }

            // 3. Main structural scanning pipeline loop
            rows.forEach(row => {
                const passengerName = row.getAttribute("data-passenger")?.toLowerCase() || "";
                const rowStatus = row.getAttribute("data-status");
                const rowTeller = row.getAttribute("data-teller");

                const matchesSearch = passengerName.includes(searchTerm);
                const matchesStatus = (statusFilter === "" || rowStatus === statusFilter);
                const matchesTeller = (tellerFilter === "" || rowTeller === tellerFilter);

                if (matchesSearch && matchesStatus && matchesTeller) {
                    if (row.style.display === "none") {
                        row.style.display = ""; // Put it back into the layout flow
                        row.style.animation = 'none';
                        row.offsetHeight; // Force reflow step
                        row.style.animation = `rowSlideIn 0.35s cubic-bezier(0.22,1,0.36,1) ${delayIndex * 40}ms both`;
                    }
                    visibleCount++;
                    delayIndex++;
                } else {
                    row.style.display = "none";
                }
            });

            // 4. DYNAMIC FEEDBACK SYSTEM: Inject a professional notice row if no bookings match the parameters
            if (visibleCount === 0) {
                const emptyTr = document.createElement("tr");
                emptyTr.className = "sys-table-empty-row";

                // Colspan="17" ensures the cell stretches gracefully across all structural logging data indices
                emptyTr.innerHTML = `
                    <td colspan="17">
                        <i class="fas fa-folder-open"></i>
                        No matching reservation logs found for "${escHtml(document.getElementById("searchPassenger").value)}"
                    </td>
                `;
                tbody.appendChild(emptyTr);
            }

            // 5. Update the count metrics badge directly
            document.getElementById("resCountBadge").innerText = visibleCount + (visibleCount === 1 ? " booking" : " bookings");
        }


           
            // TOAST LOGIC
                    function showToast(message = "Filters reset successfully!", type = "success") {
                let toast = document.getElementById("filterToast");

                if (!toast) {
                    toast = document.createElement("div");
                    toast.id = "filterToast";
                    toast.className = "sys-toast";
                    document.body.appendChild(toast);
                }

                // Default configuration (Success - Green theme)
                let iconClass = "fa-check-circle";
                let accentColor = "#10b981";

                // Dynamic coloring states
                if (type === "error" || type === "danger") {
                    iconClass = "fa-times-circle";
                    accentColor = "#ef4444"; // 🔴 Solid red color theme
                } else if (type === "warning") {
                    iconClass = "fa-exclamation-triangle";
                    accentColor = "#f59e0b"; // 🟡 Amber/Orange color theme
                }

                // Apply a clean accent edge stripe to the left side/corner corner of the toast container
                toast.style.borderLeft = `4px solid ${accentColor}`;
                toast.innerHTML = `<i class="fas ${iconClass}" style="color: ${accentColor}; font-size: 14px;"></i> <span>${message}</span>`;

                toast.classList.add("show");

                if (window.toastTimer) {
                    clearTimeout(window.toastTimer);
                }

                window.toastTimer = setTimeout(() => {
                    toast.classList.remove("show");
                }, 3000);
            }

