            /* Cancel Icon Hover Physics */
            .btn-action-icon.btn-cancel-icon {
                color: #dc2626;
                background: #fff5f5;
                border-color: #fca5a5;
            }

                .btn-action-icon.btn-cancel-icon:hover {
                    background: #dc2626 !important;
                    border-color: #dc2626 !important;
                    color: #ffffff !important;
                    transform: translateY(-1px);
                    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.2);
                }


        /* =================================================================
           RIGID TABLE CANVAS LAYOUT REINFORCEMENT
           ================================================================= */

        /* 1. Freeze column width engines */
        .sys-table {
            table-layout: fixed !important; /* Disables dynamic content-based resizing entirely */
            width: 100% !important;
            min-width: 1750px !important; /* Sets an unmoving canvas area for all 17 logging columns */
            border-collapse: collapse;
        }

            /* 2. Lock down cell behaviors so text truncation happens inside fixed boundaries */
            .sys-table th,
            .sys-table td {
                white-space: nowrap !important;
                overflow: hidden !important;
                text-overflow: ellipsis !important; /* Places neat trailing dots if data gets pinched */
                padding: 10px 8px !important;
            }

            /* 3. Explicitly allocate unmovable pixel sizes for every header index column */
            .sys-table thead th:nth-child(1) {
                width: 45px;
            }
            /* Checkbox */
            .sys-table thead th:nth-child(2) {
                width: 110px;
            }
            /* ID Reference */
            .sys-table thead th:nth-child(3) {
                width: 125px !important;
            }
            /* Trip ID */
            .sys-table thead th:nth-child(4) {
                width: 110px;
            }
            /* Bus Name */
            .sys-table thead th:nth-child(5) {
                width: 85px;
            }
            /* Body No. */
            .sys-table thead th:nth-child(6) {
                width: 140px;
            }
            /* Passenger */
            .sys-table thead th:nth-child(7) {
                width: 115px;
            }
            /* Contact */
            .sys-table thead th:nth-child(8) {
                width: 190px;
            }
            /* Route String */
            .sys-table thead th:nth-child(9) {
                width: 130px;
            }
            /* Created At */
            .sys-table thead th:nth-child(10) {
                width: 115px;
            }
            /* Travel Date */
            .sys-table thead th:nth-child(11) {
                width: 115px;
            }
            /* Departure Time */
            .sys-table thead th:nth-child(12) {
                width: 65px;
            }
            /* Seat Number */
            .sys-table thead th:nth-child(13) {
                width: 85px;
            }
            /* Type Badge */
            .sys-table thead th:nth-child(14) {
                width: 95px;
            }
            /* Total Fare Cost */
            .sys-table thead th:nth-child(15) {
                width: 110px;
            }
            /* Processing Teller */
            .sys-table thead th:nth-child(16) {
                width: 100px;
            }
            /* Status Pill Container */
            .sys-table thead th:nth-child(17) {
                width: 90px;
            }
        /* Action Row Button Block */

        /* 4. Secure the scrollable wrapper boundaries */
        .sys-table-wrap {
            width: 100% !important;
            max-width: 100% !important;
            overflow-x: auto !important; /* Keeps horizontal movement inside this block only */
            overflow-y: hidden !important;
            min-height: 320px !important; /* Anchors vertical bounce when table filters to 0 records */
            background: #ffffff;
            position: relative;
        }














        /* =================================================================
   MODAL ANIMATION FLOW & SECONDARY BUTTON REFINEMENTS
