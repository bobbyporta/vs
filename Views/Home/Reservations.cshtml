        </div>

        @* RESERVATIONS TABLE *@
        <div class="sys-card" style="border-radius:var(--radius-lg,16px); overflow:hidden;">
            <div class="sys-card-header">
                <h5 class="sys-card-title"><i class="fas fa-book-open"></i> Reservations Log</h5>
                <span class="sys-count-badge" id="resCountBadge">
                    @(ViewBag.Reservations != null ? ((List<PUBReservationSystem.Models.Reservation>)ViewBag.Reservations).Count : 0) bookings
                </span>
            </div>
            <div class="sys-table-wrap">
                <table class="sys-table" id="reservationsTable">
                    <thead>
                        <tr>
                            <th style="width:40px; text-align:center;"><input type="checkbox" id="selectAllCheckbox" onclick="toggleSelectAll()"></th>
                            <th>ID Reference</th>
                            <th>Trip ID</th>
                            <th>Bus Name</th>
                            <th>Body No.</th>
                            <th>Passenger</th>
                            <th>Contact</th>
                            <th>Route</th>
                            <th>Created At</th>
                            <th>Travel Date</th>
                            <th>Departure Time</th>
                            <th>Seat</th>
                            <th>Type</th>
                            <th>Fare</th>
                            <th>Teller</th>
                            <th style="text-align:center;">Status</th>
                            <th class="sticky-action-col" style="text-align:center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="reservationsTableBody">
                        @if (ViewBag.Reservations != null)
                        {
                            var reservations = (List<PUBReservationSystem.Models.Reservation>)ViewBag.Reservations;
                            foreach (var res in reservations)
                            {
                                var route = res.Trip != null ? $"{res.Trip.Origin} → {res.Trip.Destination}" : "N/A";
                                var dep = res.Trip?.Scheduled_Departure_Time?.ToString("hh:mm tt") ?? "—";
                                var tName = res.CreatedBy?.Employee?.Full_Name ?? res.CreatedBy?.Username ?? "System";
                                var pill = res.Status == "Cancelled" ? "status-cancelled" : res.Status == "Completed" ? "status-completed" : "status-confirmed";

                                var tripId = res.Trip_ID?.ToString() ?? "—";
                                var busName = res.Trip?.Bus?.Bus_Name ?? "TBA";
                                var bodyNo = res.Trip?.Bus?.Body_Bus_Number?.ToString() ?? "TBA";

                                <tr data-status="@res.Status" data-teller="@res.User_ID"
                                    data-res-id="@res.Reservation_ID" data-passenger="@res.Passenger_Name"
                                    data-route="@route" data-date="@res.Reservation_Date.ToString("MMM dd, yyyy")"
                                    data-seat="@res.Seat_Number" data-amount="@res.Total_Amount">
                                    <td style="text-align:center;">
                                        <input type="checkbox" class="reservation-checkbox"
                                               data-id="@res.Reservation_ID" data-name="@res.Passenger_Name"
                                               data-seat="@res.Seat_Number" data-route="@route"
                                               data-date="@res.Reservation_Date.ToString("MMM dd, yyyy")" data-dep="@dep"
                                               data-amount="@res.Total_Amount.ToString("N2")" data-type="@res.Passenger_Type"
                                               data-trip="@tripId" data-bus="@busName" data-body="@bodyNo">
                                    </td>
                                    <td class="ref-id-text">@res.Reservation_ID</td>
                                    <td style="font-weight:600; color:var(--navy-800,#0f1c3f);">@tripId</td>
                                    <td style="font-weight:600;">@busName</td>
                                    <td style="color:var(--text-secondary);">@bodyNo</td>
                                    <td style="font-weight:500;">@res.Passenger_Name</td>
                                    <td style="color:var(--text-secondary);">@(res.Contact_Number ?? "—")</td>
                                    <td style="color:var(--text-secondary);">@route</td>
                                    <td style="color:var(--text-secondary); font-size:11px;">@res.Created_At.ToString("MMM dd, hh:mm tt")</td>
                                    <td style="color:var(--text-secondary);">@res.Reservation_Date.ToString("MMM dd, yyyy")</td>
                                    <td style="font-weight:500; font-size:12px;">@dep</td>
                                    <td style="font-weight:700; color:var(--navy-800,#0f1c3f);">@res.Seat_Number</td>
                                    <td><span style="font-size:11px; font-weight:600; color:var(--text-secondary);">@res.Passenger_Type</span></td>
                                    <td style="font-weight:600; color:var(--green,#0fa66e);">₱@res.Total_Amount.ToString("N2")</td>
                                    <td style="color:var(--text-secondary); font-size:12px;">@tName</td>
                                    <td style="text-align:center;"><span class="res-status-pill @pill">@res.Status</span></td>
                                    <td class="sticky-action-col" style="text-align:center;">
                                        <div class="table-action-row" style="display: flex; justify-content: center; gap: 6px;">
                                            @if (res.Status != "Cancelled" && (ViewBag.Role == "Admin" || ViewBag.Role == "HeadTeller" || ViewBag.Role == "Teller"))
                                            {
                                               @* <button class="btn-action-icon btn-edit-icon" title="Modify Trip & Seat assignment"
                                                        onclick="openEditReservationModal(this)"
                                                        data-id="@res.Reservation_ID"
                                                        data-passenger="@res.Passenger_Name"
                                                        data-current-trip="#@tripId"
                                                        data-current-trip-id="@res.Trip_ID"
                                                        data-current-route="@route"
                                                        data-current-date="@res.Reservation_Date.ToString("yyyy-MM-dd")"
                                                        data-current-seat="@res.Seat_Number"
                                                        data-current-fare="@res.Total_Amount">
                                                    <i class="fas fa-edit"></i>
                                                </button> *@

                                                <button class="btn-action-icon btn-cancel-icon" title="Void Booking Record"
                                                        onclick="cancelReservation('@res.Reservation_ID', this)">
                                                    <i class="fas fa-ban"></i>
                                                </button>
                                            }
                                            else if (res.Status == "Cancelled")
                                            {
                                                <span class="badge-table-muted" style="color:var(--tb-text-muted); font-size:12px; font-weight:600;">Closed</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

