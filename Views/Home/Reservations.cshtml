                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>

                @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "HeadTeller")
                {
                    <select id="filterTeller" class="form-control filter-dropdown-operator" onchange="filterReservations()">
                        <option value="">All Operators</option>
                        @if (ViewBag.Tellers != null)
                        {
                            @foreach (var teller in (List<PUBReservationSystem.Models.Users>)ViewBag.Tellers)
                            {
                                <option value="@teller.User_ID">@(teller.Employee?.Full_Name ?? teller.Username)</option>
                            }
