        <!-- FOOTER -->
        <footer class="sys-footer">
            <span>&copy; 2026 PUB Reservation System &mdash; All rights reserved.</span>
            <a href="/Home/Privacy">Privacy Policy</a>
        </footer>

    </div>

    <!-- TOAST CONTAINER -->
    <div class="toast-container" id="sysToastContainer"></div>

    <div id="idleWarningModal" class="sys-modal-overlay">
        <div class="sys-modal modal-sm">
            <div class="modal-header-sys">
                <h4 class="modal-title-sys"><i class="fas fa-clock"></i> Session Expiring</h4>
            </div>
            <div class="modal-body-sys" style="text-align: center;">
                <p style="font-size: 14px; margin-bottom: 20px;">
                    You have been inactive. For security, you will be logged out in
                    <strong id="idleCountdown" style="color: var(--red);">30</strong> seconds.
                </p>
                <button class="btn-primary-sys" onclick="keepAlive()">Keep me Logged In</button>
            </div>
        </div>
    </div>



    <div class="sys-modal-overlay" id="profileModal">
        <div class="sys-modal">
            <div class="modal-header-sys">
                <h3 class="modal-title-sys"><i class="fas fa-user-cog"></i> Account Settings</h3>
                <button class="modal-close-sys" onclick="closeModalSafe('profileModal')"><i class="fas fa-times"></i></button>
            </div>

            <div class="modal-body-split">
                <div class="modal-sidebar">
                    <button class="modal-nav-btn active" onclick="switchTab('tab-profile', this)">Personalization</button>
                    <button class="modal-nav-btn" onclick="switchTab('tab-security', this)">System Security</button>
                </div>

                <div class="modal-main">
                    <div id="tab-profile" class="tab-content active">
                        <div class="profile-upload-area" style="text-align: center; margin-bottom: 20px;">
                            <img src="@(Context.Session.GetString("ProfilePicturePath") ?? "/images/default-avatar.png")"
                                 id="previewPhoto"
                                 style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid #e2e8f0;"
                                 onerror="this.src='/images/default-avatar.png';">

                            <input type="file" id="photoInput" accept="image/*" onchange="previewImage(this)" style="display:none;">
                            <br><br>
                            <button type="button" class="btn-ghost-sys" onclick="document.getElementById('photoInput').click()">Change Photo</button>
                        </div>
                        <div class="form-group-sys">
                            <label>Display Name</label>
                            <input type="text" id="updateName" class="form-control-sys" value="@Context.Session.GetString("User_FullName")">
                        </div>
                    </div>

                    <div id="tab-security" class="tab-content">
                        <div class="security-grid-container" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">

                            <div class="form-group-sys" style="margin-bottom: 0;">
                                <label>Username</label>
                                <input type="text" id="updateUsername" class="form-control-sys" value="@Context.Session.GetString("Username")" placeholder="Enter username">
                            </div>

