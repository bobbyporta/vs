                    <span class="user-name">@username</span>
                    <span class="user-role-label">@role</span>
                </div>
                <i class="fas fa-cog" style="margin-left: auto; font-size: 12px; opacity: 0.5;"></i>
            </button>

            <a href="/Account/Logout" class="nav-link-item logout">
                <i class="fas fa-sign-out-alt"></i> Sign Out
            </a>
        </div>

    </aside>

    <!-- MAIN SHELL -->
    <div class="sys-main">



        <!--Top Bar-->

        @using Microsoft.AspNetCore.Http
        @{
            // Retrieve the active login branch configuration context dynamically
            var rawBranchName = Context.Session.GetString("Branch_Name") ?? ViewBag.BranchName as string ?? "Manila Branch";

            // Sanitize string (e.g., "Baguio Branch" -> "Baguio") so it maps seamlessly to weather API locations
            var weatherCityQuery = rawBranchName.Replace("Branch", "", StringComparison.OrdinalIgnoreCase).Trim();
        }

        <header class="sys-topbar">
            <div class="topbar-breadcrumb">
                <span>PUB System</span>
                <i class="fas fa-chevron-right"></i>
                <span class="crumb-active">@(ViewData["Title"] ?? "Dashboard")</span>
