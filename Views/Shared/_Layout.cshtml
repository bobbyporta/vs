                </div>

                <div class="topbar-chip">
                    <i class="fas fa-clock" style="color:#3b82f6;"></i>
                    <strong id="sysLiveClock" class="topbar-clock">--:--:-- --</strong>
                </div>

                <div class="topbar-user-chip">
