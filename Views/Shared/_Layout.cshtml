                <span class="brand-sub">Reservation & Trips System</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Main</span>

            <a href="/Home" class="nav-link-item @(Context.Request.Path.Value == "/Home" || Context.Request.Path.Value == "/" ? "active" : "")">
                <i class="fas fa-th-large"></i> Dashboard
            </a>

            @if (isAdmin || isHeadTeller || isTeller)
            {
                <a href="/Home/Reservations" class="nav-link-item @(Context.Request.Path.Value.Contains("Reservations") ? "active" : "")">
                    <i class="fas fa-ticket-alt"></i> Reservations
                </a>
            }

            <a href="/Home/Trips" class="nav-link-item @(Context.Request.Path.Value.Contains("Trips") ? "active" : "")">
                <i class="fas fa-route"></i> Trips & Schedules
            </a>

            <span class="nav-section-label">Fleet</span>
            <a href="/Home/Buses" class="nav-link-item @(Context.Request.Path.Value.Contains("Buses") ? "active" : "")">
                <i class="fas fa-bus-alt"></i> Buses
            </a>

            @if (isAdmin)
            {
                <a href="/Home/RouteManagement" class="nav-link-item @(Context.Request.Path.Value.Contains("RouteManagement") ? "active" : "")">
                    <i class="fas fa-map-marked-alt"></i> Routes
                </a>
                <a href="/Home/Branches" class="nav-link-item @(Context.Request.Path.Value.Contains("Branches") ? "active" : "")">
                    <i class="fas fa-code-branch"></i> Branches
                </a>
            }

            @if (isAdmin || isHeadTeller)
            {
                <span class="nav-section-label">Administration</span>
                <a href="/Home/Employees" class="nav-link-item @(Context.Request.Path.Value.Contains("Employees") ? "active" : "")">
                    <i class="fas fa-users"></i> Employees
                </a>
            }

            @if (isAdmin)
            {
                <a href="/Home/UserManagement" class="nav-link-item @(Context.Request.Path.Value.Contains("UserManagement") ? "active" : "")">
                    <i class="fas fa-user-cog"></i> User Management
                </a>
                <a href="/Home/Archives" class="nav-link-item @(Context.Request.Path.Value.Contains("Archives") ? "active" : "")">
                    <i class="fas fa-archive"></i> System Archives
                </a>
                <a href="/Home/AuditLogs" class="nav-link-item @(Context.Request.Path.Value.Contains("AuditLogs") ? "active" : "")">
                    <i class="fas fa-history"></i> Audit Logs
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <button type="button" class="sidebar-user-btn" onclick="openModalSafe('profileModal')">
                <div class="user-avatar">@avatarLetter</div>
