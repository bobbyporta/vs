            </div>

            <div class="modal-footer-sys">
                <button class="btn-ghost-sys" onclick="closeModalSafe('profileModal')">Cancel</button>
                <button class="btn-primary-sys" onclick="saveProfileChanges()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        (function () {
            var IDLE_TIMEOUT = 180000; // 3 minutes
            var WARNING_TIME = 150000; // 2.5 minutes
            var idleTimer = null;
            var countdownTimer = null;

            function registerActivity() {
                // Only update lastActivity if the modal is NOT currently showing
                var modal = document.getElementById('idleWarningModal');
                if (!modal.classList.contains('active')) {
                    localStorage.setItem('lastActivity', Date.now());
                }
            }

            function checkIdle() {
                var lastActivity = parseInt(localStorage.getItem('lastActivity') || Date.now());
                var currentTime = Date.now();
                var diff = currentTime - lastActivity;

                if (diff >= IDLE_TIMEOUT) {
                    // Time's up, force logout
                    window.location.href = '/Account/Logout';
                } else if (diff >= WARNING_TIME) {
                    // Show modal if we hit warning threshold
                    showWarning(Math.round((IDLE_TIMEOUT - diff) / 1000));
                }
            }

            function showWarning(secondsRemaining) {
                var modal = document.getElementById('idleWarningModal');
                var display = document.getElementById('idleCountdown');

                // Add BOTH classes so it works on older pages AND the new Buses page!
                modal.classList.add('active');
                modal.classList.add('active-modal');

                // Optional: Lock background scroll if the page supports it
                document.body.classList.add('modal-open');

                display.textContent = secondsRemaining;
            }

            // 🛑 This is the ONLY function that resets the session
            window.keepAlive = function() {
                localStorage.setItem('lastActivity', Date.now()); // Reset timer
                var modal = document.getElementById('idleWarningModal');

                // Remove BOTH classes to hide it
                modal.classList.remove('active');
                modal.classList.remove('active-modal');
                document.body.classList.remove('modal-open');
            };

            // Track activity to update heartbeat
            var events = ['mousedown', 'mousemove', 'keypress', 'scroll', 'touchstart'];
            events.forEach(function (name) {
                document.addEventListener(name, registerActivity, true);
            });

            // Run the check every second
            setInterval(checkIdle, 1000);

            // Initialize
            registerActivity();
        })();


                document.addEventListener("DOMContentLoaded", function () {
            // ==========================================
            // 1. ENGINE: LIVE REACTIVE CLOCK
            // ==========================================
            function initializeLiveSystemClock() {
                const clockElement = document.getElementById("sysLiveClock");
                if (!clockElement) return;

                setInterval(function () {
                    const now = new Date();
                    let hours = now.getHours();
                    const minutes = String(now.getMinutes()).padStart(2, '0');
                    const seconds = String(now.getSeconds()).padStart(2, '0');
                    const ampm = hours >= 12 ? 'PM' : 'AM';

                    hours = hours % 12;
                    hours = hours ? hours : 12; // Handle structural midnight transformation
                    const formattedHours = String(hours).padStart(2, '0');

                    clockElement.textContent = `${formattedHours}:${minutes}:${seconds} ${ampm}`;
                }, 1000);
            }

            // ==========================================
            // 2. ENGINE: ASYNC BRANCH-AWARE WEATHER
            // ==========================================
        async function initializeBranchWeather() {
            const widget = document.getElementById("sysWeatherWidget");
            const iconEl = document.getElementById("sysWeatherIcon");
            const tempEl = document.getElementById("sysWeatherTemp");
            const cityEl = document.getElementById("sysWeatherCity");

            if (!widget) return;

            // Pull sanitized branch query string from the HTML data attribute
            const cityQuery = widget.getAttribute("data-city");

            // 🛑 REMEMBER: Replace with your actual OpenWeatherMap API Token Key
            const apiKey = "4c7543e4fd95e7fb82243e41a0fdd740";
            const fetchUrl = `https://api.openweathermap.org/data/2.5/weather?q=${encodeURIComponent(cityQuery)},PH&units=metric&appid=${apiKey}`;

            try {
                const response = await fetch(fetchUrl);
                if (!response.ok) throw new Error("API pipeline error");

                const data = await response.json();

                // 1. Update text fields dynamically
                tempEl.textContent = `${Math.round(data.main.temp)}°C`;
                cityEl.textContent = cityQuery + " Terminal";

                // 2. Extract OpenWeatherMap Icon Condition String (e.g., "01d", "04n", "10d")
                const weatherIconCode = data.weather[0].icon;
                const isNight = weatherIconCode.endsWith('n'); // True if evening/night condition

                // Reset icon properties cleanly before re-rendering
                iconEl.className = "";
                iconEl.removeAttribute("style");

                // =================================================================
                // REAL-TIME WEATHER CONDITION & TIME-OF-DAY ENGINE
                // =================================================================
                switch (weatherIconCode.substring(0, 2)) {

                    case "01": // CLEAR SKIES
                        if (isNight) {
                            iconEl.className = "fas fa-moon";
                            iconEl.style.color = "#38bdf8"; // Radiant lunar blue
                            widget.style.borderLeft = "3px solid #1e40af"; // Deep night navy border
                        } else {
                            iconEl.className = "fas fa-sun";
                            iconEl.style.color = "#eab308"; // High-noon amber yellow
                            widget.style.borderLeft = "3px solid #eab308"; // Bright sunny border
                        }
                        break;

                    case "02": // FEW CLOUDS (PARTLY CLOUDY)
                        if (isNight) {
                            iconEl.className = "fas fa-cloud-moon";
                            iconEl.style.color = "#94a3b8"; // Soft slate gray night cloud
                            widget.style.borderLeft = "3px solid #475569";
                        } else {
                            iconEl.className = "fas fa-cloud-sun";
                            iconEl.style.color = "#f59e0b"; // Golden sun peaking past clouds
                            widget.style.borderLeft = "3px solid #f59e0b";
                        }
                        break;

                    case "03": // SCATTERED CLOUDS
                    case "04": // BROKEN / OVERCAST CLOUDS (HEAVY CLOUDY)
                        iconEl.className = "fas fa-cloud";
                        iconEl.style.color = "#64748b"; // Low-exposure gray overcast skies
                        widget.style.borderLeft = "3px solid #64748b";
                        break;

                    case "09": // SHOWER RAIN
                    case "10": // MODERATE / HEAVY RAIN
                        iconEl.className = "fas fa-cloud-showers-heavy";
                        iconEl.style.color = "#3b82f6"; // Active rainy downpour blue
                        widget.style.borderLeft = "3px solid #2563eb"; // Water blue border accent
                        break;

                    case "11": // THUNDERSTORMS
                        iconEl.className = "fas fa-bolt";
                        iconEl.style.color = "#eab308"; // Electric lightning spark flash
                        widget.style.borderLeft = "3px solid #7c3aed"; // Threatening purple warning border
                        break;

                    case "50": // MIST / ATMOSPHERIC FOG
                        iconEl.className = "fas fa-smog";
                        iconEl.style.color = "#cbd5e1"; // Hazy terminal mist
                        widget.style.borderLeft = "3px solid #cbd5e1";
                        break;

                    default: // DEFAULT RECOVERY ESCAPE PATH
                        iconEl.className = isNight ? "fas fa-moon" : "fas fa-sun";
                        iconEl.style.color = isNight ? "#38bdf8" : "#eab308";
                        widget.style.borderLeft = "3px solid #3b82f6";
                }

            } catch (error) {
                console.error("Weather refresh crash:", error);
                // Clean baseline visual recovery standard fallback
                iconEl.className = "fas fa-cloud";
                iconEl.style.color = "#94a3b8";
                tempEl.textContent = "28°C";
                widget.style.borderLeft = "3px solid #e2e8f0";
            }
        }

            // Initialize execution tracks
            initializeLiveSystemClock();
            initializeBranchWeather();

            // Allow users to force manually update by double clicking the chip layout boundary box
            document.getElementById("sysWeatherWidget").addEventListener("dblclick", initializeBranchWeather);
        });




































    </script>

    <script>
        // ===== LIVE CLOCK =====
        function updateSysClock() {
            var el = document.getElementById('sysLiveClock');
            if (el) el.textContent = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        updateSysClock();
        setInterval(updateSysClock, 1000);

        // ===== TOAST SYSTEM =====
        function showToast(message, type) {
            type = type || 'info';
            var icons = { success: 'fa-circle-check', error: 'fa-circle-xmark', warning: 'fa-triangle-exclamation', info: 'fa-circle-info' };
            var container = document.getElementById('sysToastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast-item ' + type;
            toast.innerHTML =
                '<i class="fas ' + (icons[type] || icons.info) + ' toast-icon"></i>' +
                '<span class="toast-msg">' + message + '</span>' +
                '<button class="toast-close" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>';
            container.appendChild(toast);
            setTimeout(function() { if (toast.parentElement) toast.remove(); }, 4500);
        }
        window.showToast = showToast;

        // ===== MODAL HELPERS =====
                // ===== MODAL HELPERS =====
        function openModal(id) {
            var el = document.getElementById(id);
            if (el) {
                el.classList.add('active');
                el.classList.add('active-modal');
                document.body.classList.add('modal-open'); // Added this to lock scroll
            }
        }

        function closeModal(id) {
            var el = document.getElementById(id);
            if (el) {
                el.classList.remove('active');
                el.classList.remove('active-modal');
                document.body.classList.remove('modal-open');
            }
        }

        // Create aliases so both 'openModal' and 'openModalSafe' work
        window.openModal = openModal;
        window.closeModal = closeModal;
        window.openModalSafe = openModal;
        window.closeModalSafe = closeModal;

        // Close modal on overlay click
               // Locate this in _Layout.cshtml and update the condition
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('sys-modal-overlay')) {
                // Only close if it's NOT the profile modal
                if (e.target.id !== 'profileModal') {
                    e.target.classList.remove('active');
                    e.target.classList.remove('active-modal');
                    document.body.classList.remove('modal-open');
                }
            }
        });


                window.togglePass = function(id, icon) {
            var input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        };

        // ===== SESSION CHECKER =====
        var _sessionInterval = null;
        function startSessionChecker() {
            if (_sessionInterval) clearInterval(_sessionInterval);
            _sessionInterval = setInterval(function() {
                fetch('/Home/CheckSessionStatus')
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (!data.isActive) {
                            clearInterval(_sessionInterval);
                            showToast('Your account has been deactivated. Redirecting...', 'warning');
                            setTimeout(function() { window.location.href = '/Account/Logout'; }, 2200);
                        }
                    })
                    .catch(function() {});
            }, 5000);
        }

        if (document.body.getAttribute('data-logged-in') === 'true') {
            startSessionChecker();
        }

        // ===== TEMPDATA NOTIFICATIONS =====
        document.addEventListener('DOMContentLoaded', function() {
            @if (TempData["SuccessMessage"] != null)
            {
                    <text>showToast('@Html.Raw(JavaScriptEncoder.Default.Encode(TempData["SuccessMessage"].ToString()))', 'success');</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                    <text>showToast('@Html.Raw(JavaScriptEncoder.Default.Encode(TempData["ErrorMessage"].ToString()))', 'error');</text>
            }
        });





         function previewImage(input) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            $('#previewPhoto').attr('src', e.target.result);
        }
        reader.readAsDataURL(input.files[0]);
    }
}
        




                window.switchTab = function(tabId, btn) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            // Deactivate all buttons
            document.querySelectorAll('.modal-nav-btn').forEach(b => b.classList.remove('active'));

            // Show selected tab
            document.getElementById(tabId).classList.add('active');
            btn.classList.add('active');
        };

        // Updated Save logic
                // Submits the form data via AJAX
        function saveProfileChanges() {
            var newPassword = $('#newPass').val();
            var confirmPassword = $('#confirmPass').val();
            var currentPassword = $('#currPass').val();

            // Validation check before triggering network traffic
            if (newPassword !== confirmPassword) {
                if (typeof showToast === "function") showToast("New passwords do not match.", "error");
                return;
            }

            // Pack inputs into a FormData object to handle image upload fields
            var formData = new FormData();

            var fileInput = document.getElementById('photoInput');
            if (fileInput.files.length > 0) {
                formData.append("ProfileImage", fileInput.files[0]);
            }

            formData.append("DisplayName", $('#updateName').val());
            formData.append("Username", $('#updateUsername').val());
            formData.append("CurrentPassword", currentPassword);
            formData.append("NewPassword", newPassword);

            $.ajax({
                url: '/Home/SaveChangesAccountSettings', // Update this path if your action uses a different route
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if (response.success) {
                        if (typeof showToast === "function") showToast(response.message, "success");

                        // Clear the password fields out for security
                        $('#currPass').val('');
                        $('#newPass').val('');
                        $('#confirmPass').val('');

                        // Reload the page after a brief delay to apply changes across the layout cleanly
                        setTimeout(function() {
                            location.reload();
                        }, 800);
                    } else {
                        if (typeof showToast === "function") showToast(response.message, "error");
                    }
                },
                error: function() {
                    if (typeof showToast === "function") showToast("An internal processing error stopped your updates.", "error");
                }
            });
        }



    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
